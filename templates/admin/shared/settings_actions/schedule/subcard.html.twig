<div class="space-y-2 mt-5">
    {# Description #}
    {{ include('/admin/shared/settings_actions/_description.html.twig', {
        description: field.vars.attr.description,
    }) }}

    <div class="flex justify-between items-center relative" data-controller="card">
        <div class="text-sm font-semibold text-gray-700">
            {{ field_label }}
        </div>
        <img class="w-5 h-5 cursor-pointer"
                {{ stimulus_target('card', 'button') }}
                {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
             src="{{ asset('resources/logos/info_icon.svg') }}"
             alt="info_icon"/>

        {# Cron Field Description #}
        <div class="bg-indigo-400 rounded-lg p-2 z-10 w-3/4 text-center text-white transition ease-in-out duration-300 absolute hidden"
             style="left: 50%; top: 100%; transform: translateX(-50%) translateY(8px); z-index: 10;"
             data-card-target="info">
            {{ description }}
        </div>
    </div>

    <div>
        {# Frequency field #}
        {% if frequency_field is defined and frequency_field is not null %}
            <div class="form-group">
                <div class="flex items-center gap-3 py-2">
                    {{ form_widget(frequency_field, {attr: {class: 'form-widget-range flex-1'}}) }}
                    <span class="text-sm text-gray-700 font-medium"> {{ frequency_field.vars.value is null or frequency_field.vars.value is empty ? 1 : frequency_field.vars.value }}</span>
                </div>
                <div class="text-red-500 text-sm mt-1">
                    {{ form_errors(frequency_field) }}
                </div>
            </div>
        {% endif %}

        {# Field #}
        <div class="form-group">
            {{ form_widget(field, {attr: {class: 'form-widget'}}) }}
            <div class="text-red-500 text-sm mt-1">
                {{ form_errors(field) }}
            </div>
        </div>
    </div>
</div>
