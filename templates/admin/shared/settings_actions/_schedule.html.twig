{% set groups = {
    DELETE_UNCONFIRMED_USERS_CRON: [
        'DELETE_UNCONFIRMED_USERS_CRON_advanced',
        'DELETE_UNCONFIRMED_USERS_CRON_frequency',
        'DELETE_UNCONFIRMED_USERS_CRON_day_of_week',
        'DELETE_UNCONFIRMED_USERS_CRON_day_of_month',
        'DELETE_UNCONFIRMED_USERS_CRON_time',
        'DELETE_UNCONFIRMED_USERS_CRON_interval',
        'DELETE_UNCONFIRMED_USERS_CRON_startDate',
        'DELETE_UNCONFIRMED_USERS_CRON_endDate',
    ],
    USERS_WHEN_PROFILE_EXPIRES_CRON: [
        'USERS_WHEN_PROFILE_EXPIRES_CRON_advanced',
        'USERS_WHEN_PROFILE_EXPIRES_CRON_frequency',
        'USERS_WHEN_PROFILE_EXPIRES_CRON_day_of_week',
        'USERS_WHEN_PROFILE_EXPIRES_CRON_day_of_month',
        'USERS_WHEN_PROFILE_EXPIRES_CRON_time',
        'USERS_WHEN_PROFILE_EXPIRES_CRON_interval',
        'USERS_WHEN_PROFILE_EXPIRES_CRON_startDate',
        'USERS_WHEN_PROFILE_EXPIRES_CRON_endDate',
    ],
    LDAP_SYNC_CRON: [
        'LDAP_SYNC_CRON_advanced',
        'LDAP_SYNC_CRON_frequency',
        'LDAP_SYNC_CRON_day_of_week',
        'LDAP_SYNC_CRON_day_of_month',
        'LDAP_SYNC_CRON_time',
        'LDAP_SYNC_CRON_interval',
        'LDAP_SYNC_CRON_startDate',
        'LDAP_SYNC_CRON_endDate',
    ],
} %}

{% set fieldTitles = {
    '_advanced': 'Advanced Mode',
    '_frequency': 'Frequency',
    '_day_of_week': 'Day of Week',
    '_day_of_month': 'Day of Month',
    '_time': 'Time of Execution',
    '_interval': 'Interval (Time Between Runs)',
    '_startDate': 'Start Date',
    '_endDate': 'End Date',
} %}

<div {{ stimulus_controller('cron-toggle') }}>
    <form action="{{ path('admin_dashboard_settings_schedule') }}" method="post" enctype="multipart/form-data">
        {{ form_row(form._token) }}

        <div class="flex flex-col mx-4 space-x-3 space-y-2">
            <div>
                <label class="inline-flex items-center cursor-pointer gap-x-3">
                    {{ form_label(form.use_advanced_mode, null, {label_attr: {class: 'me-3'}}) }}
                    {{ form_widget(form.use_advanced_mode, {attr: {class: 'sr-only peer', 'data-cron-toggle-target': 'toggle', 'data-action': 'cron-toggle#toggleChanged'}}) }}
                    <div class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-bg-lightGreen rounded-full
                        peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white
                        after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border
                        after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#68D391]"></div>
                    {{ form_errors(form.use_advanced_mode) }}
                </label>
            </div>
        </div>

        <div class="grid gap-4 lg:grid-cols-2 xl:grid-cols-3 p-2 z-0 mt-4">
            {% for groupName, fields in groups %}
                <div class="transition hover:-translate-y-1 hover:shadow bg-white rounded-md p-6 w-full"
                     id="{{ groupName }}" {{ stimulus_controller('card') }}>
                    <div class="flex flex-row justify-between">
                        <div class="text-base font-medium text-center break-normal md:break-all">
                            {% set displayName = {
                                DELETE_UNCONFIRMED_USERS_CRON: 'Delete Unconfirmed Account Automation',
                                USERS_WHEN_PROFILE_EXPIRES_CRON: 'Profile Expiration Notification Automation',
                                LDAP_SYNC_CRON: 'LDAP Synchronization Automation',
                            }[groupName] %}
                            <h1 class="text-base md:text-lg whitespace-nowrap">{{ displayName }}</h1>
                        </div>
                        <label class="flex items-center bg-opacity-40">
                            <img class="w-6 cursor-pointer"
                                    {{ stimulus_target('card', 'button') }}
                                    {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
                                 src="{{ asset('resources/logos/info_icon.svg') }}"
                                 alt="info_icon"/>
                        </label>
                    </div>

                    <div class="space-y-2 mt-5">
                        {% set renderedTitles = [] %}
                        {% for fieldName in fields %}
                            {# Find suffix key for this field #}
                            {% set suffix = fieldTitles|keys|filter(s => fieldName ends with s)|first %}
                            {% set toggleTarget =
                                suffix == '_advanced' ? 'advanced' :
                                suffix == '_frequency' ? 'frequency' :
                                suffix == '_time' ? 'time' :
                                suffix == '_day_of_week' ? 'day_of_week' :
                                suffix == '_day_of_month' ? 'day_of_month' :
                                suffix == '_interval' ? 'interval' :
                                suffix == '_startDate' ? 'startDate' :
                                suffix == '_endDate' ? 'endDate' : null %}

                            {# Show the title only once per suffix type #}
                            {% if suffix is not null and suffix not in renderedTitles %}
                                <div data-cron-toggle-title="{{ toggleTarget }}" data-cron-toggle-group="{{ groupName }}"
                                     class="text-sm font-semibold text-gray-700 mt-4">
                                    {{ fieldTitles[suffix] }}
                                </div>
                                {% set renderedTitles = renderedTitles|merge([suffix]) %}
                            {% endif %}

                            <div class="form-group" data-cron-toggle-group="{{ groupName }}">
                                {{ form_widget(attribute(form, fieldName), {
                                    attr: {
                                        class: 'form-widget',
                                        placeholder: 'e.g. 0 0 * * *',
                                        'data-cron-toggle-target': toggleTarget,
                                        'data-cron-toggle-group': groupName,
                                    },
                                }) }}
                            </div>
                        {% endfor %}
                    </div>

                    {{ include('/admin/shared/settings_actions/_description.html.twig', {
                        description: attribute(form, fields[0]).vars.attr.description,
                    }) }}

                    <div class="mt-2 -mb-2 text-center text-red-500 text-base">
                        {% for fieldName in fields %}
                            {{ form_errors(attribute(form, fieldName)) }}
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="mt-6 divider-solid"></div>

        <div class="mt-6 flex flex-row w-full justify-end items-center gap-2">
            <a href="{{ path('app_dashboard_regenerate_code_admin', {type: 'settingSchedule'}) }}"
               onclick="return confirm('Are you sure you want to reset to the default settings?')"
               class="text-sm hover:text-red-600 font-bold p-2 rounded-lg transition ease-in duration-300">
                Reset
            </a>

            <button type="submit" class="btn-primary"
                    onclick="return confirm('Are you sure you want to apply this new changes?')">Save Changes
            </button>
        </div>
    </form>
</div>
