<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Opening App...</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #090B2F;
            color: #fff;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: white;
            color: #3F474D;
            border-radius: 1rem;
            padding: 3rem 2.5rem;
            text-align: center;
            max-width: 480px;
            width: 90%;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .spinner-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 120px;
            height: 120px;
            margin: 0 auto 1.75rem;
        }

        .spinner-wrapper svg {
            width: 120px;
            height: 120px;
        }

        .spinner-wrapper img {
            position: absolute;
            width: 60px;
            height: 60px;
            object-fit: contain;
        }

        .text-primary {
            color: #7DB928;
        }

        .title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .subtitle {
            font-size: 0.9rem;
            color: #6b7280;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        .divider {
            border: none;
            border-top: 1px solid #e5e7eb;
            margin-bottom: 1.5rem;
        }

        .hint {
            font-size: 0.8rem;
            color: #9ca3af;
            margin-bottom: 1.25rem;
        }

        .dots span {
            display: inline-block;
            animation: pulse 1.2s ease-in-out infinite;
            opacity: 0.3;
        }

        .dots span:nth-child(1) {
            animation-delay: 0s;
        }

        .dots span:nth-child(2) {
            animation-delay: 0.3s;
        }

        .dots span:nth-child(3) {
            animation-delay: 0.6s;
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 0.3;
            }
            50% {
                opacity: 1;
            }
        }

        .btn {
            display: inline-block;
            background: #7DB928;
            color: white;
            font-weight: 600;
            font-size: 0.9rem;
            padding: 0.75rem 2rem;
            border-radius: 0.5rem;
            text-decoration: none;
            transition: background 0.2s;
        }

        .btn:hover {
            background: #6aa620;
        }
    </style>
</head>
<body>
{% set bgUrl = data.WALLPAPER_IMAGE.value != '/resources/images/wallpaper.png'
    ? data.WALLPAPER_IMAGE.value
    : '/resources/images/background.png' %}

<div class="relative min-h-screen px-4 sm:px-6 lg:px-8 bg-center bg-cover"
     style="background-image: url('{{ bgUrl }}');"> help me out here pls

<div class="card">

    <div class="spinner-wrapper">
        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            {# Static light gray track #}
            <circle
                    cx="50" cy="50" r="45"
                    fill="none"
                    stroke="#F3F4F6"
                    stroke-width="2"
            />
            {# Animated green arc #}
            <circle
                    cx="50" cy="50" r="45"
                    fill="none"
                    stroke="#7DB928"
                    stroke-width="4"
                    stroke-linecap="round"
                    stroke-dasharray="1 212"
                    stroke-dashoffset="0"
            >
                <animate
                        attributeName="stroke-dasharray"
                        values="1 212; 70 212; 1 212"
                        keyTimes="0; 0.5; 1"
                        dur="1.6s"
                        calcMode="spline"
                        keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"
                        repeatCount="indefinite"
                />
                <animate
                        attributeName="stroke-dashoffset"
                        values="0; -106; -212"
                        keyTimes="0; 0.5; 1"
                        dur="1.6s"
                        calcMode="spline"
                        keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"
                        repeatCount="indefinite"
                />
            </circle>
        </svg>

        <img src="{{ asset('resources/logos/openroaming-loading-logo.svg') }}"
             alt="Loading"
        />
    </div>

    <p class="title">
        Opening the app<span class="dots"><span>.</span><span>.</span><span>.</span></span>
    </p>

    <p class="subtitle">
        The app should open automatically in a moment.
    </p>

    <hr class="divider">

    <p class="hint">Did the popup get blocked? Click below to continue.</p>
</div>
</body>
</html>
