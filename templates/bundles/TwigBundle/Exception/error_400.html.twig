{% set bgUrl = data.wallpaperImageName.value != '/resources/images/wallpaper.png'
    ? data.wallpaperImageName.value
    : '/resources/images/background.png' %}

{% extends 'base.html.twig' %}

{% block title %}
    {{ data.title.value }} - {{ status_code }} {{ status_title }}
{% endblock %}

{% block body %}
    <div class="relative min-h-screen px-4 sm:px-6 lg:px-8 bg-center bg-cover"
         style="background-image: url('{{ bgUrl }}');">
        <div class="relative w-full h-full p-8 xl:pl-[130px] xl:pr-[150px] xl:pt-[210px] bg-center bg-cover z-10">

            <div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full p-10 text-center mx-auto">

                {# Icon on top, bigger and centered #}
                <div class="flex justify-center mb-4">
                    <div class="flex items-center justify-center w-48 h-24 rounded-full">
                        <twig:ux:icon name="wba:info-error"/>
                    </div>
                </div>

                {# Title with custom colour #}
                <h1 class="text-3xl font-bold mb-4" style="color: #3F474D;">
                    {{ status_title }} {{ status_code }}
                </h1>

                <p class="text-base text-gray-600 mb-2">
                    Oops, it looks like something went wrong!
                </p>

                <p class="text-sm text-gray-500 mb-6">
                    Please let us know what you were doing when this error occurred.<br>
                    We'll fix it as soon as possible. Our apologies for any inconvenience caused.
                </p>

                <div class="flex justify-center mb-4">
                    <a href="{{ path('app_landing') }}"
                       class="my-6 w-[250px] btn-primary inline-block">
                        Return to the Homepage
                    </a>
                </div>

                {% if exception is defined and exception.message is not empty %}
                    <div class="mt-12 w-full bg-gray-100 shadow-inner rounded-lg p-6 text-left text-sm text-gray-700 overflow-x-auto">
                        <h2 class="text-xl font-semibold text-gray-800 mb-4">Error Details</h2>
                        {{ exception.message|nl2br }}
                    </div>
                {% endif %}


                {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
                    <div class="mt-10 flex justify-center items-center gap-10">
                        <img class="h-10 object-contain" src="{{ data.customerLogoName.value }}" alt="Logo">
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
