{# templates/bundles/TwigBundle/Exception/error.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}
    {{ data.title.value }} - {{ status_code }} {{ status_title }}
{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gray-50 flex flex-col justify-center items-center px-4 sm:px-6 lg:px-8">

        {# Customer Logo #}
        {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
            <div class="mb-10">
                <img class="h-14 object-contain" src="{{ data.customerLogoName.value }}" alt="Logo">
            </div>
        {% endif %}

        <div class="text-center">
            <div class="inline-flex items-center justify-center space-x-4">
                <p class="text-7xl font-extrabold text-indigo-700">{{ status_code }}</p>

                <div class="flex items-center justify-center w-12 h-12 rounded-full bg-indigo-600 text-white shadow-lg
              transition-transform duration-300
              hover:animate-spin hover:scale-110 hover:shadow-2xl cursor-pointer">
                    <twig:ux:icon name="wba:maintenance" class="w-6 h-6" />
                </div>
            </div>

            <h1 class="mt-2 text-3xl font-bold text-gray-900">{{ status_title }}</h1>

            <p class="mt-4 text-lg text-gray-600">
                {% if status_code == 404 %}
                    The page or resource you’re looking for could not be found.
                {% elseif status_code >= 500 %}
                    The server encountered an error. Please try again later.
                {% else %}
                    Something went wrong. Please try again.
                {% endif %}
            </p>

            <div class="mt-6">
                <button
                        class="inline-block bg-indigo-600 text-white px-4 py-2 rounded-lg shadow hover:bg-indigo-700 transition"
                        onClick="window.history.back();"
                >
                    Go Back
                </button>
            </div>
        </div>

        {# Optional: Technical Details in Dev or if exception is passed #}
        {% if exception is defined and exception.message is not empty %}
            <div class="mt-12 w-full max-w-3xl bg-white shadow-md rounded-lg p-6">
                <h2 class="text-xl font-semibold text-gray-800 mb-4">Error Details</h2>
                <div class="overflow-x-auto text-sm text-gray-700">
                    {{ exception.message|nl2br }}
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
