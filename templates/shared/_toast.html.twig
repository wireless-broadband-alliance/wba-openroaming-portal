<div
        {{ stimulus_controller('toast') }}
        {{ stimulus_target('toast', 'toast') }}
        class="overflow-hidden transition-all duration-300 ease-in-out"
        style="max-height: 0; opacity: 0;"
>
    <div class="{{ toast_type }} flex items-center gap-3">
        <twig:ux:icon name="wba:info" class="w-4 h-4 flex-shrink-0 fill-current"/>
        <span class="flex-1">{{ message }}</span>
        <button {{ stimulus_action('toast', 'close') }} class="flex-shrink-0 opacity-60 hover:opacity-100 transition-opacity ml-auto">
            <twig:ux:icon name="wba:cross-circle-rounded" class="w-4 h-4 fill-current"/>
        </button>
    </div>
</div>
