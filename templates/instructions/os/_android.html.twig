<div class="instructions">
    {# Introduction #}
    <p class="introduction">
        {{ 'introduction'|trans({}, 'android') }}
    </p>

    {# Get the correct image folder based on locale, fallback to en #}
    {% set locale = app.request.locale in ['pt', 'en'] ? app.request.locale : 'en' %}
    {% set imgPath = 'resources/instructions/android/' ~ locale %}

    <div class="card-container">
        <div class="card-grid">

            {# Items 1 to 4 #}
            {% for i in 1..4 %}
                <a href="{{ asset(imgPath ~ '/item' ~ i ~ '.jpeg') }}" target="_blank" class="card">
                    <div class="card-number">{{ i }}</div>
                    <div class="flex justify-center">
                        <img src="{{ asset(imgPath ~ '/item' ~ i ~ '.jpeg') }}"
                             alt="Item {{ i }}"
                             class="card-image">
                    </div>
                    <p class="card-description">
                        {{ ('item' ~ i ~ '.description')|trans({}, 'android') }}
                    </p>
                </a>
            {% endfor %}

            {# Item 5 full width #}
            <a href="{{ asset(imgPath ~ '/item5.jpeg') }}" target="_blank"
               class="card md:col-span-2">
                <div class="card-number">5</div>
                <div class="flex justify-center">
                    <img src="{{ asset(imgPath ~ '/item5.jpeg') }}"
                         alt="Item 5"
                         class="card-image">
                </div>
                <p class="card-description">
                    {{ 'item5.description'|trans({}, 'android') }}
                </p>
            </a>

        </div>
    </div>
</div>
