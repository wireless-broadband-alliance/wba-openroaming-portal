{% extends '/dashboard/base.html.twig' %}

{% block title %}{{ 'adminPageWBA'|trans({}, 'statistics') }}{% endblock %}

{% block container %}
    {# Header #}
    <div class="flex flex-col lg:flex-row space-y-4 lg:space-y-0 justify-end items-center mb-10">
        {{ include('dashboard/shared/_date_filter_form.html.twig', {
            routeName: 'admin_dashboard_statistics',
        }) }}
    </div>

    {# Charts #}
    <div class="grid gap-8 grid-cols-1 lg:grid-cols-2 2xl:grid-cols-3">
        {# SMS & Email #}
        <div class="bg-white rounded-lg px-5 pt-4 pb-6 flex flex-col gap-4 shadow">
            {# Header #}
            <div class="flex items-start justify-between">
                <h1 class="text-lg font-medium">{{ 'portalSMSorEmail'|trans({}, 'statistics') }}</h1>
                <div class="text-right">
                    <span class="block text-gray-400 text-xs">Total</span>
                    <strong class="text-gray-900 text-base">{{ SMSEmailTotal|number_format(0, '.', ' ') }}</strong>
                </div>
            </div>

            {# Chart + Legend #}
            <div class="flex items-center justify-start gap-8 py-2">

                {# Doughnut — larger to match Figma #}
                <div class="relative flex-shrink-0 overflow-visible" style="width:200px; height:200px;">
                    <canvas style="width:200px; height:200px;"
                            data-controller="statistics"
                            data-statistics-target="chart"
                            data-chart-style="sms-email"
                            data-chart-data="{{ SMSEmailDataJson }}"></canvas>
                    <div id="sms-email-tooltip"
                         style="display:none; position:absolute; top:-40px; left:50%; transform:translateX(-50%);
                background:#111; color:#fff; font-size:0.75rem; padding:4px 10px;
                border-radius:6px; white-space:nowrap; pointer-events:none;">
                    </div>
                </div>

                {# Legend #}
                <ul class="flex flex-col gap-4 text-sm">
                    {% for item in SMSEmailLegend %}
                        <li class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full flex-shrink-0 sms-email-dot-{{ loop.index0 }}"></span>
                            <span class="text-gray-500">{{ item.label }} ({{ item.pct }}%)</span>
                            <strong class="ml-1 text-gray-900">{{ item.count|number_format(0, '.', ' ') }}</strong>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>

        {# Authentication #}
        <div class="bg-white rounded-lg px-5 py-3 flex flex-col gap-6 shadow">
            <h1 class="text-lg font-medium">{{ 'authentication'|trans({}, 'statistics') }}</h1>
            <div class="relative h-64">
                <canvas data-controller="statistics"
                        data-statistics-target="chart"
                        data-chart-style="authentication"
                        data-chart-data="{{ authenticationDataJson }}"></canvas>
            </div>
        </div>

        {# Devices #}
        <div class="bg-white rounded-lg px-5 py-3 flex flex-col gap-6 shadow">
            <h1 class="text-lg font-medium">{{ 'devices'|trans({}, 'statistics') }}</h1>
            <div class="relative h-64">
                <canvas data-controller="statistics"
                        data-statistics-target="chart"
                        data-chart-style="devices"
                        data-chart-data="{{ devicesDataJson }}"></canvas>
            </div>
        </div>

        {# Platform Status #}
        <div class="bg-white rounded-lg px-5 py-3 flex flex-col gap-6 shadow">
            <h1 class="text-lg font-medium">{{ 'userCreatedIn'|trans({}, 'statistics') }}</h1>
            <div class="relative h-64">
                <canvas data-controller="statistics"
                        data-statistics-target="chart"
                        data-chart-style="platform-status"
                        data-chart-data="{{ platformStatusDataJson }}"></canvas>
            </div>
        </div>

        {# Users Management #}
        <div class="bg-white rounded-lg px-5 py-3 flex flex-col gap-6 shadow">
            <h1 class="text-lg font-medium">{{ 'usersManagement'|trans({}, 'statistics') }}</h1>
            <div class="relative h-64">
                <canvas data-controller="statistics"
                        data-statistics-target="chart"
                        data-chart-style="users-verified"
                        data-chart-data="{{ usersVerifiedDataJson }}"></canvas>
            </div>
        </div>

        {# Users 2FA Configuration Status #}
        <div class="bg-white rounded-lg px-5 py-3 flex flex-col gap-6 shadow">
            <h1 class="text-lg font-medium">{{ 'users2FAStatus'|trans({}, 'statistics') }}</h1>
            <div class="relative h-64">
                <canvas data-controller="statistics"
                        data-statistics-target="chart"
                        data-chart-style="2fa"
                        data-chart-data="{{ twoFADataJson }}"></canvas>
            </div>
        </div>
    </div>
{% endblock %}
