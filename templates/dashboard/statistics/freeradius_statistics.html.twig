{% extends 'dashboard/base.html.twig' %}

{% block title %}{{ 'adminPageWBA'|trans({}, '_header_admin') }}{% endblock %}

{% block container %}

    {# Main two-column layout wrapper #}
    <div class="flex flex-col lg:flex-row gap-6">

    {# ── LEFT COLUMN ── #}
    <div class="flex flex-col gap-6 lg:w-2/3">

    {# Date filter - top right aligned #}
    <div class="flex justify-end items-center">
        {% if exportFreeradiusStatistics == constant('App\\Enum\\OperationMode::ON').value %}
            <div class="mr-auto">
                <a href="{{ path('admin_dashboard_statistics_freeradius_export', {startDate: selectedStartDate, endDate: selectedEndDate}) }}"
                   onclick="return confirm('...')"
                   class="btn-primary">
                    {{ 'exportStatistics'|trans({}, 'freeradius_statistics') }}
                </a>
            </div>
        {% endif %}
        {{ include('dashboard/shared/_date_filter_form.html.twig', {
            routeName: 'admin_dashboard_statistics_freeradius',
        }) }}
    </div>

    {# Authentication Attempts #}
    <div class="w-full bg-white rounded-lg px-5 py-4 flex flex-col gap-4 shadow">
        <div class="flex flex-row justify-between items-start">
            <h1 class="text-lg font-medium">{{ 'authenticationAttempts'|trans({}, 'freeradius_statistics') }}</h1>
            <div class="flex gap-8 text-sm">
                <div class="flex flex-col items-start">
                    <span class="text-gray-400 text-xs">{{ 'accepted'|trans({}, 'freeradius_statistics') }}</span>
                    <strong class="text-green-500 text-base">{{ authCounts['Accepted'] }}</strong>
                </div>
                <div class="flex flex-col items-start">
                    <span class="text-gray-400 text-xs">{{ 'rejected'|trans({}, 'freeradius_statistics') }}</span>
                    <strong class="text-red-500 text-base">{{ authCounts['Rejected'] }}</strong>
                </div>
                <div class="flex flex-col items-start">
                    <span class="text-gray-400 text-xs">{{ 'totalAttempts'|trans({}, 'freeradius_statistics') }}</span>
                    <strong class="text-gray-800 text-base">{{ authCounts['Accepted'] + authCounts['Rejected'] }}</strong>
                </div>
            </div>
        </div>

        {# Top chart — Accepted #}
        <div class="w-full relative">
            <p class="text-xs font-medium text-primary mb-1">{{ 'accepted'|trans({}, 'freeradius_statistics') }}</p>
            <div class="h-40">
                <canvas
                        id="authAcceptedChart"
                        data-controller="freeradius-statistics"
                        data-chart-type="accepted"
                        data-freeradius-statistics-target="chart"
                        data-chart-data="{{ authAttemptsJson }}"
                        data-label-accepted="{{ 'accepted'|trans({}, 'freeradius_statistics') }}"
                        data-label-rejected="{{ 'rejected'|trans({}, 'freeradius_statistics') }}"
                ></canvas>
            </div>
        </div>

        {# Divider #}
        <div class="border-t border-gray-100"></div>

        {# Bottom chart — Rejected #}
        <div class="w-full relative">
            <p class="text-xs font-medium text-red-500 mb-1">{{ 'rejected'|trans({}, 'freeradius_statistics') }}</p>
            <div class="h-40">
                <canvas
                        id="authRejectedChart"
                        data-controller="freeradius-statistics"
                        data-chart-type="rejected"
                        data-freeradius-statistics-target="chart"
                        data-chart-data="{{ authAttemptsJson }}"
                        data-label-accepted="{{ 'accepted'|trans({}, 'freeradius_statistics') }}"
                        data-label-rejected="{{ 'rejected'|trans({}, 'freeradius_statistics') }}"
                ></canvas>
            </div>
        </div>
    </div>

    {# Average Session Time + Session Time - side by side #}
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

        {# Average Session Time #}
        <div class="w-full bg-white rounded-lg px-5 py-3 shadow">
            <div class="flex flex-row justify-between items-start pb-2">
                <h1 class="text-lg font-medium">{{ 'averageSessionTime'|trans({}, 'freeradius_statistics') }}</h1>
                <div class="text-right border-l border-gray-200 pl-3">
                    <p class="text-xs text-gray-400">{{ 'totalAverageOf'|trans({}, 'freeradius_statistics') }}</p>
                    <strong class="text-base">{{ sessionTimeAverage }}</strong>
                </div>
            </div>
            <div class="w-full h-48 relative">
                <canvas
                        id="sessionTimeChart"
                        data-controller="freeradius-statistics"
                        data-freeradius-statistics-target="chart"
                        data-chart-type="session"
                        data-chart-data="{{ sessionTimeJson }}"
                ></canvas>
            </div>
        </div>

        {# Total Session Time #}
        <div class="w-full bg-white rounded-lg px-5 py-3 shadow">
            <div class="flex flex-row justify-between items-start pb-2">
                <h1 class="text-lg font-medium">{{ 'averageSessionTime'|trans({}, 'freeradius_statistics') }}</h1>
                <div class="text-right border-l border-gray-200 pl-3">
                    <p class="text-xs text-gray-400">{{ 'totalOf'|trans({}, 'freeradius_statistics') }}</p>
                    <strong class="text-base">{{ sessionTimeAverage }}</strong>
                </div>
            </div>
            <div class="w-full h-48 relative">
                <canvas
                        id="totalTimeChart"
                        data-controller="freeradius-statistics"
                        data-freeradius-statistics-target="chart"
                        data-chart-type="sessionTotal"
                        data-chart-data="{{ totalTimeJson }}"
                ></canvas>
            </div>
        </div>
    </div>

    {# Access Points Usage #}
    <div class="w-full bg-white rounded-lg p-4 shadow">
        <h1 class="text-lg font-medium pb-4">{{ 'accessPointsUsage'|trans({}, 'freeradius_statistics') }}</h1>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-veryLightGreen">
                <tr>
                    <th class="w-3/12 p-4 text-left text-xs text-gray-500 uppercase tracking-wider">
                        {{ 'Usage'|trans({}, 'freeradius_statistics') }}
                    </th>
                    <th class="p-4 text-left text-xs text-gray-500 uppercase tracking-wider">
                        Mac Address:SSID
                    </th>
                </tr>
                </thead>
                <tbody>
                {% if ApUsage is empty %}
                    <tr>
                        <td colspan="2">
                            <div class="bg-red-500/50 rounded-full m-4 p-1 text-red-500 font-semibold text-center text-sm">
                                {{ 'noDataAvailable'|trans({}, 'freeradius_statistics') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    {% for ap, count in ApUsage %}
                        <tr name="{{ ap }}">
                            <td class="px-8 py-2">
                                <div class="px-2 py-1 w-full bg-veryLightGreen rounded-full flex justify-center items-center">
                                    <span>{{ count }}</span>
                                </div>
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap">
                                <span>{{ ap }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                {% endif %}
                </tbody>
            </table>
        </div>
        <div class="m-4">
            <hr class="w-full h-0.5 bg-gray-300/50 border-0 rounded">
            {{ include('dashboard/shared/pagination/_pagination_ApUsage.html.twig', {
                label: 'apUsagePerPage'|trans({}, 'freeradius_statistics'),
                route: 'admin_dashboard_statistics_freeradius',
                occurrencies: totalApCount,
            }) }}
        </div>
    </div>

    </div>{# end LEFT COLUMN #}

    {# ── RIGHT COLUMN (sidebar) ── #}
    <div class="flex flex-col gap-6 lg:w-1/3">

    {# Current Authentications #}
    <div class="w-full bg-white rounded-2xl p-6 shadow-sm" {{ stimulus_controller('card') }}>
        <div class="flex flex-row justify-between mb-4">
            <h2 class="text-base font-semibold text-gray-700">
                {{ 'currentAuthentications'|trans({}, 'freeradius_statistics') }}
            </h2>
            <label class="flex items-center bg-opacity-40">
                <img class="w-6 cursor-pointer"
                        {{ stimulus_target('card', 'button') }}
                        {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
                     src="{{ asset('resources/logos/info_icon.svg') }}"
                     alt="info_icon" />
            </label>
        </div>

        <div>
            {{ include('/dashboard/shared/settings_actions/_description.html.twig', {
                description: 'currentAuthsDateWarning'|trans({}, 'freeradius_statistics'),
            }) }}
        </div>

        <div class="flex items-center gap-3">
            {% if totalCurrentAuths >= 1 %}
                <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
                    <twig:ux:icon class="w-6 text-[#7DB928]" name="wba:security-check-ok" />
                </div>
                <span class="text-lg font-bold text-[#7DB928]">{{ totalCurrentAuths }}</span>
            {% else %}
                <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
                    <twig:ux:icon class="w-6 text-red-500" name="wba:security-check-error" />
                </div>
                <span class="text-sm font-medium text-red-500">{{ 'noDataAvailable'|trans({}, 'freeradius_statistics') }}</span>
            {% endif %}
        </div>
    </div>

    {# Traffic Total #}
    <div class="w-full bg-white rounded-2xl p-6 shadow-sm">
        <h2 class="text-base font-semibold text-gray-700 mb-5">{{ 'trafficTotal'|trans({}, 'freeradius_statistics') }}</h2>

        {% set input = totalTrafficFreeradius.input_bytes ?? 0 %}
        {% set output = totalTrafficFreeradius.output_bytes ?? 0 %}
        {% set hasData = input > 0 or output > 0 %}

        <div class="flex gap-8">
            {# Uploads #}
            <div class="flex flex-col gap-2">
                <p class="text-xs text-gray-400">{{ 'uploads'|trans({}, 'freeradius_statistics') }}</p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full {{ hasData ? 'bg-gray-100' : 'bg-red-100' }} flex items-center justify-center flex-shrink-0">
                        <twig:ux:icon class="w-6 fill-current {{ hasData ? 'text-gray-500' : 'text-red-500' }}"
                                      name="wba:upload-freeradius-statistics" />
                    </div>
                    <p class="text-base {{ hasData ? 'font-bold text-gray-800' : 'text-red-500' }} leading-tight">
                        {% if hasData %}
                            {{ totalTrafficFreeradius.input_human }}
                        {% else %}
                            {{ 'noDataAvailable'|trans({}, 'freeradius_statistics') }}
                        {% endif %}
                    </p>
                </div>
            </div>

            {# Downloads #}
            <div class="flex flex-col gap-2">
                <p class="text-xs text-gray-400">{{ 'downloads'|trans({}, 'freeradius_statistics') }}</p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full {{ hasData ? 'bg-gray-100' : 'bg-red-100' }} flex items-center justify-center flex-shrink-0">
                        <twig:ux:icon class="w-6 fill-current {{ hasData ? 'text-gray-500' : 'text-red-500' }}"
                                      name="wba:download-freeradius-statistics" />
                    </div>
                    <p class="text-base {{ hasData ? 'font-bold text-gray-800' : 'text-red-500' }} leading-tight">
                        {% if hasData %}
                            {{ totalTrafficFreeradius.output_human }}
                        {% else %}
                            {{ 'noDataAvailable'|trans({}, 'freeradius_statistics') }}
                        {% endif %}
                    </p>
                </div>
            </div>
        </div>
    </div>

    {# Wi-Fi Standards Usage #}
    <div class="w-full bg-white rounded-lg p-4 shadow">
        <h1 class="text-lg font-medium pb-4">{{ 'WiFiStandardsUsage'|trans({}, 'freeradius_statistics') }}</h1>
        <div class="w-full h-48 relative">
            <canvas
                    id="wifiTagsChart"
                    data-controller="freeradius-statistics"
                    data-freeradius-statistics-target="chart"
                    data-chart-type="wifiTags"
                    data-chart-data="{{ wifiTagsJson }}"
            ></canvas>
        </div>
    </div>

    {# Realm Usage #}
    <div class="w-full bg-white rounded-lg p-4 shadow">
        <h1 class="text-lg font-medium pb-4">{{ 'realmUsage'|trans({}, 'freeradius_statistics') }}</h1>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-veryLightGreen">
                <tr>
                    <th class="p-4 text-left text-xs text-gray-500 uppercase tracking-wider">
                        {{ 'Usage'|trans({}, 'freeradius_statistics') }}
                    </th>
                    <th class="p-4 text-left text-xs text-gray-500 uppercase tracking-wider">
                        {{ 'realmName'|trans({}, 'freeradius_statistics') }}
                    </th>
                </tr>
                </thead>
                <tbody>
                {% if realmsUsage is empty %}
                    <tr>
                        <td colspan="2">
                            <div class="bg-red-500/50 rounded-full m-4 p-1 text-red-500 font-semibold text-center text-sm">
                                {{ 'noDataAvailable'|trans({}, 'freeradius_statistics') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    {% for index, label in realmsUsage %}
                        <tr name="{{ label }}">
                            <td class="px-8 py-2">
                                <div class="px-2 py-1 w-full bg-veryLightGreen rounded-full flex justify-center items-center">
                                    <span>{{ label }}</span>
                                </div>
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap">
                                <span>{{ index }}</span>
                            </td>
                        </tr>
                    {% endfor %}
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>

    </div>{# end RIGHT COLUMN #}

    </div>{# end two-column wrapper #}

    <hr class="mb-8 mt-16 divider">
{% endblock %}
