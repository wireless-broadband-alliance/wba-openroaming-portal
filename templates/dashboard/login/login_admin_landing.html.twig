{% extends '/landing/base.html.twig' %}

{% block title %}
    {{ data.title.value }}
{% endblock %}

{% block second_col %}

    {# Toasts #}
    {{ block('toast_messages') }}

    {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
        <img class="w-[120px] h-[58px] object-scale-down mt-[75px]" src="{{ data.customerLogoName.value }}" alt="Logo"/>
    {% endif %}

    <div class="{{ data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value ? 'pt-[28px]' : 'pt-[161px]' }} leading-7">
        <p class="font-bold text-xl">{{ 'adminLoginPage'|trans({}, 'login_admin_landing') }}</p>
        <p class="text-lg">{{ 'loginPageMessage'|trans({}, 'login_admin_landing') }}</p>
    </div>

    {# Form Column #}
    {{ form_start(form) }}

    {% if data.AUTH_METHOD_REGISTER_ENABLED.value and data.AUTH_METHOD_REGISTER_ENABLED.value == 'true' %}
        {% set label = 'emailPhoneNumber'|trans({}, 'login_admin_landing') %}
    {% elseif data.AUTH_METHOD_REGISTER_ENABLED.value == 'true' %}
        {% set label = 'Email' %}
    {% elseif data.AUTH_METHOD_SMS_REGISTER_ENABLED.value == 'true' %}
        {% set label = 'phoneNumber'|trans({}, 'login_admin_landing') %}
    {% else %}
        {% set label = 'Email' %}
    {% endif %}

    {# UUID #}
    <div class="relative mt-[32px]">
        {{ form_label(form.uuid, label, {label_attr: {class: 'form-label'}}) }}
        {{ form_widget(form.uuid, {
            attr: {
                class: 'form-widget',
                placeholder: 'enterYour'|trans({}, 'login_admin_landing') ~ label|lower,
            },
            full_name: 'uuid',
        }) }}
    </div>

    {# Password #}
    <div class="relative mt-[32px]">
        {{ form_label(form.password, null, {label_attr: {class: 'form-label'}}) }}
        {{ form_widget(form.password, {
            attr: {
                class: 'form-widget',
                placeholder: 'enterPassword'|trans({}, 'login_admin_landing'),
            },
            full_name: 'password',
        }) }}
    </div>

    {# Turnstile Checker #}
    {% if data.TURNSTILE_CHECKER.value == constant('App\\Enum\\OperationMode::ON').value %}
        <div class="ml-3 mt-5">
            {{ form_row(form.security, {full_name: 'security'}) }}
        </div>
    {% endif %}

    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

    <div class="my-[32px] flex justify-start gap-4">
        <button type="submit" class="w-[220px] btn-primary">
            {{ 'login'|trans({}, 'login_admin_landing') }}
        </button>
        <!--
        {% if data.PLATFORM_MODE.value != constant('App\\Enum\\PlatformMode::DEMO').value %}
            <a href="{{ path('app_landing') }}" class="w-[220px] btn-secondary">
                {{ 'chooseAnother'|trans({}, 'login_admin_landing') }}
            </a>
        {% endif %}
       -->
    </div>

    {# Divider #}
    <div class="my-[25px] divider"></div>
    {% if data.PLATFORM_MODE.value != constant('App\\Enum\\PlatformMode::DEMO').value %}

        {% if data.AUTH_METHOD_REGISTER_ENABLED.value or data.AUTH_METHOD_SMS_REGISTER_ENABLED.value == 'true' %}
            <p class="mt-2 text-sm">{{ 'forgetPassword'|trans({}, 'login_admin_landing') }}

            {% if data.AUTH_METHOD_REGISTER_ENABLED.value == 'true' %}
                <a href="{{ path('app_site_forgot_password_email') }}" class="font-semibold text-primary underline">email</a>
            {% endif %}

            {% if data.AUTH_METHOD_REGISTER_ENABLED.value and data.AUTH_METHOD_SMS_REGISTER_ENABLED.value == 'true' %}or{% endif %}

            {% if data.AUTH_METHOD_SMS_REGISTER_ENABLED.value == 'true' %}
                <a href="{{ path('app_site_forgot_password_sms') }}"
                   class="font-semibold text-primary underline">{{ 'phoneNumber'|trans({}, 'login_admin_landing') }}</a>.
            {% endif %}

            {% if data.AUTH_METHOD_REGISTER_ENABLED.value or data.AUTH_METHOD_SMS_REGISTER_ENABLED.value == 'true' %}

                <p class="mt-2 text-sm">{{ 'noAccount'|trans({}, 'login_admin_landing') }}

                    {% if data.AUTH_METHOD_REGISTER_ENABLED.value == 'true' %}
                        <a href="{{ path('app_register') }}"
                           class="font-semibold text-primary underline">email</a>
                    {% endif %}

                    {% if data.AUTH_METHOD_REGISTER_ENABLED.value and data.AUTH_METHOD_SMS_REGISTER_ENABLED.value == 'true' %}
                        {{ 'or'|trans({}, 'login_admin_landing') }}
                    {% endif %}

                    {% if data.AUTH_METHOD_SMS_REGISTER_ENABLED.value == 'true' %}
                        <a href="{{ path('app_register_sms') }}"
                           class="font-semibold text-primary underline">{{ 'phoneNumber'|trans({}, 'login_admin_landing') }}</a>.
                    {% endif %}
                </p>
            {% endif %}
        {% endif %}
    {% endif %}

    {{ form_rest(form) }}
    {{ form_end(form) }}
{% endblock %}
