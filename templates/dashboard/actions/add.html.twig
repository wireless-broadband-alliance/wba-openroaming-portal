{% extends '/dashboard/base.html.twig' %}

{% block title %}Add User{% endblock %}

{% block container %}
  {{ form_start(form) }}
  {{ form_errors(form) }}
  <div class="p-6 bg-white rounded-lg shadow-md">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      {# Account Type #}
      <div class="relative">
        {{ form_label(form.accountType, 'accountType'|trans({}, 'UserAddType'), {label_attr: {class: 'form-label'}}) }}
        {{ form_widget(form.accountType, {attr: {class: 'form-widget'}}) }}
        <div class="text-red-500 mt-1">{{ form_errors(form.accountType) }}</div>
      </div>

      {# Roles (SUPER_ADMIN only) #}
      {% if form.roles is defined %}
        <div class="relative">
          {{ form_label(form.roles, 'roles'|trans({}, 'UserAddType'), {label_attr: {class: 'form-label'}}) }}
          {{ form_widget(form.roles, {attr: {class: 'form-widget'}}) }}
          <div class="text-red-500 mt-1">{{ form_errors(form.roles) }}</div>
        </div>
      {% endif %}

      {# Email #}
      <div class="relative lg:col-span-2">
        {{ form_label(form.email, 'Email', {label_attr: {class: 'form-label'}}) }}
        {{ form_widget(form.email, {attr: {class: 'form-widget'}}) }}
        <div class="text-red-500 mt-1">{{ form_errors(form.email) }}</div>
      </div>

      {# Phone Number #}
      <div class="relative lg:col-span-2">
        {{ form_label(form.phoneNumber, 'phoneNumber'|trans({}, 'UserAddType'), {label_attr: {class: 'form-label'}}) }}
        {{ form_widget(form.phoneNumber, {attr: {class: 'form-widget'}}) }}
        <div class="text-red-500 mt-1">{{ form_errors(form.phoneNumber) }}</div>
      </div>

      {# First Name #}
      <div class="relative">
        {{ form_label(form.firstName, 'firstName'|trans({}, 'UserAddType'), {label_attr: {class: 'form-label'}}) }}
        {{ form_widget(form.firstName, {attr: {class: 'form-widget'}}) }}
        <div class="text-red-500 mt-1">{{ form_errors(form.firstName) }}</div>
      </div>

      {# Last Name #}
      <div class="relative">
        {{ form_label(form.lastName, 'lastName'|trans({}, 'UserAddType'), {label_attr: {class: 'form-label'}}) }}
        {{ form_widget(form.lastName, {attr: {class: 'form-widget'}}) }}
        <div class="text-red-500 mt-1">{{ form_errors(form.lastName) }}</div>
      </div>

      {# Password #}
      <div class="relative lg:col-span-2">
        {{ form_label(form.password, 'password'|trans({}, 'UserAddType'), {label_attr: {class: 'form-label'}}) }}
        {{ form_widget(form.password, {attr: {class: 'form-widget'}}) }}
        <div class="text-red-500 mt-1">{{ form_errors(form.password) }}</div>
      </div>

    </div>

    <div class="flex flex-row justify-end mt-6">
      <button type="submit" class="btn-primary w-full lg:w-auto">{{ 'applyChanges'|trans({}, 'edit') }}</button>
    </div>
  </div>
  {{ form_rest(form) }}
  {{ form_end(form) }}
{% endblock %}
