{% extends 'dashboard/shared/settings_actions/certificatesManagement/installation/base.html.twig' %}

{% block title %}
    {{ 'adminPageWBA'|trans({}, '_header_admin') }}
{% endblock %}

{% block installation_content %}

    <div class="mt-6">
        <h1 class="text-2xl sm:text-3xl font-bold leading-tight">
            {{ 'adminConfigTitle'|trans({}, 'admin_config') }}
        </h1>
        <p class="mt-3 text-gray-600 text-base sm:text-lg">
            {{ 'adminConfirmDescription'|trans({}, 'admin_config') }}
        </p>
    </div>

    <div class="my-6 divider-solid"></div>

    {{ form_start(form, {attr: {autocomplete: 'off'}}) }}

    <div class="grid gap-4 grid-cols-1 md:grid-cols-4 p-2 z-0">

        {# --- Code Card --- #}
        <div class="cert-upload-card col-span-1 sm:col-span-1 md:col-span-2 transition hover:shadow-lg hover:-translate-y-1 duration-200"
                {{ stimulus_target('radio-card', 'card') }}
                {{ stimulus_controller('card') }}>

            <div class="flex justify-between items-center mb-4">
                <h2 class="text-lg sm:text-xl font-medium text-gray-700">
                    {{ 'code'|trans({}, 'admin_config') }}
                </h2>

                <button type="button"
                        class="ml-2 p-1"
                        {{ stimulus_target('card', 'button') }}
                        {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}>
                    <img src="{{ asset('resources/logos/info_icon.svg') }}" alt="info icon" class="w-6 h-6"/>
                </button>
            </div>

            {{ include('/dashboard/shared/settings_actions/_description.html.twig', {
                description: 'codeDescription'|trans({}, 'admin_config'),
            }) }}

            <div class="mt-4 flex flex-col sm:flex-row items-center gap-3">
                {{ form_widget(form.code, {
                    attr: {
                        class: 'form-widget flex-1',
                        placeholder: 'codePlaceholder'|trans({}, 'admin_config'),
                    },
                }) }}

                <a href="{{ path('admin_dashboard_settings_certs_installation_admin_confirmation_resend') }}"
                   class="btn-secondary whitespace-nowrap mt-2 sm:mt-0">
                    {{ 'resendCode'|trans({}, 'admin_config') }}
                </a>
            </div>

            <div class="mt-2 text-red-500 text-sm">
                {{ form_errors(form.code) }}
            </div>

        </div>

    </div>

    <div class="mt-8 divider-solid"></div>

    <div class="mt-6 flex flex-col sm:flex-row justify-end items-center gap-2">
        <a href="{{ path('admin_dashboard_settings_certs_installation_admin') }}"
           class="btn-secondary w-full sm:w-auto">
            {{ 'changeEmail'|trans({}, 'admin_config') }}
        </a>

        <button type="submit"
                class="btn-primary w-full sm:w-auto"
                onclick="return confirm('{{ 'saveChangesMessage'|trans({}, 'admin_config') }}')">
            {{ 'databaseApplyBtn'|trans({}, 'admin_config') }}
        </button>
    </div>

    {{ form_row(form._token) }}
    {{ form_end(form) }}

{% endblock %}
