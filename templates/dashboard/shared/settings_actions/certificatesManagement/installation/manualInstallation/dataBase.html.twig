{% extends 'dashboard/shared/settings_actions/certificatesManagement/installation/base.html.twig' %}

{% block title %}
    {{ 'adminPageWBA'|trans({}, '_header_admin') }}
{% endblock %}

{% block installation_content %}

    <div class="mt-6 leading-7">
        <p class="font-bold text-base sm:text-lg md:text-xl lg:text-2xl">
            {{ 'databaseTitle'|trans({}, 'dataBase') }}
        </p>
        <p class="mt-3 text-sm sm:text-base md:text-lg lg:text-xl text-gray-600">
            {{ 'databaseDescription'|trans({}, 'dataBase') }}
        </p>
    </div>

    <div class="my-[25px] divider"></div>


        <div class="grid gap-4 p-2 z-0">
            <div class="grid gap-4 grid-cols-1 p-2 z-0">
                <div class="transition bg-white rounded-md p-6 w-full" >
                    <p class="font-bold text-base sm:text-lg md:text-xl lg:text-2xl">
                        {{ 'dbOpenRoamingLabel'|trans({}, 'dataBase') }}
                    </p>
                    <p class="mt-3 text-sm sm:text-base md:text-lg lg:text-xl text-gray-600">
                        {{ 'dbOpenRoamingDescription'|trans({}, 'dataBase') }}
                    </p>
                </div>
            </div>

        </div>

    {# Update Server Commands #}
    {{ include(
        'dashboard/shared/settings_actions/certificatesManagement/partials/_update_commands.html.twig',
        { commands: commands, title: 'title'|trans({}, 'config_freeradius') }
    ) }}

        <div class="mt-8 divider-solid"></div>

        <div class="mt-6 flex flex-row w-full justify-end items-center gap-2">

            <button type="submit" class="w-[160px] btn-primary" onclick="return confirm('{{ 'saveChangesMessage'|trans({}, 'dataBase') }}')">
                {{ 'databaseApplyBtn'|trans({}, 'dataBase') }}
            </button>
        </div>

{% endblock %}
