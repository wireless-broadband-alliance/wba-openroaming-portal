{% extends 'landing/authUser/base.html.twig' %}

{% block title %}
    {{ 'adminPageWBA'|trans({}, '_header_admin') }}
{% endblock %}

{% block content %}

    <div class="mt-6 leading-7">
        <p class="font-bold text-base sm:text-lg md:text-xl lg:text-2xl">
            {{ 'summaryTitle'|trans({}, 'summary') }}
        </p>
        <p class="mt-3 text-sm sm:text-base md:text-lg lg:text-xl text-gray-600">
            {{ 'summaryDescription'|trans({}, 'summary') }}
        </p>
    </div>

    <div class="my-[25px] divider"></div>

    <div class="space-y-2">
        <p><strong>Installation State:</strong> {{ Installation.installationState }}</p>
        <p><strong>DB OpenRoaming:</strong> {{ Installation.dbOpenRoaming }}</p>
        <p><strong>DB Freeradius:</strong> {{ Installation.dbFreeradius }}</p>
        <p><strong>Trusted Proxies:</strong> {{ Installation.trustedProxies }}</p>
        <p><strong>Turnstile Key:</strong> {{ Installation.turnstileKey }}</p>
        <p><strong>Turnstile Secret:</strong> {{ Installation.turnstileSecret }}</p>
        <p><strong>JWT Passphrase:</strong> {{ Installation.jwtPassphrase }}</p>
        <p><strong>Email Admin:</strong> {{ Installation.emailAdmin }}</p>
        <p><strong>Admin Confirmation:</strong> {{ Installation.adminConfirmation ? 'Sim' : 'Não' }}</p>
        <p><strong>Created At:</strong> {{ Installation.createdAt|date('d/m/Y H:i') }}</p>
        <p><strong>Updated At:</strong> {{ Installation.updatedAt ? Installation.updatedAt|date('d/m/Y H:i') : '-' }}</p>
    </div>

    <div class="mt-6 flex flex-row w-full justify-end items-center gap-2">

        <a href="{{ path('admin_dashboard_settings_certs_management') }}"
           class="w-[160px] btn-primary">
            {{ 'finish'|trans({}, 'summary') }}
        </a>
    </div>

{% endblock %}
