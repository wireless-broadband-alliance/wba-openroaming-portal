{% extends 'dashboard/shared/settings_actions/certificatesManagement/certificates/radsecproxy/base.html.twig' %}

{% block radsecproxy_content %}
    {# Warning message box #}
    <div class="toast-light-warning mb-6">
        <twig:ux:icon name="wba:info" class="w-10 md:w-5 h-10 md:h-5 inline mr-3" fill="currentColor"/>

        <span>
            {{ 'warning.root_command'|trans({}, 'upload') }}
        </span>
    </div>

    {% if commands is defined and commands is not empty %}
        <div class="border border-gray-200 rounded-xl shadow-sm overflow-hidden mt-6">
            <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex items-center gap-2">
                <twig:ux:icon class="w-5 h-5 text-primary" name="wba:terminal"/>
                <h5 class="text-lg font-semibold text-gray-800">{{ 'configTitle'|trans({}, 'config') }}</h5>
            </div>
            <div class="px-6 py-5 space-y-5 bg-white">
                {% for step in commands %}
                    <div class="space-y-2 relative" data-controller="clipboard">
                        <p class="text-sm font-medium text-gray-700">
                            {{ 'step'|trans({}, 'config') }} {{ loop.index }} – {{ step.description }}
                        </p>
                        <div class="absolute top-5 right-2">
                            <button type="button" title="Copy" aria-label="Copy code to clipboard"
                                    class="code-block-copy"
                                    data-action="click->clipboard#copyToClipboard">
                                <twig:ux:icon class="w-5 h-5" name="wba:copy"/>
                            </button>
                        </div>
                        <pre data-clipboard-target="code"
                             class="copyable-code rounded bg-gray-800 text-white p-4 font-mono overflow-x-auto relative">{{ step.command }}</pre>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <div class="mt-8 flex justify-end">
        {{ form_start(form) }}

        {# Button Submit #}
        {{ form_row(form._token) }}
        <button
                type="submit"
                class="px-6 py-2.5 bg-primary text-white font-medium rounded-lg shadow hover:bg-primary-dark focus:ring-2 focus:ring-offset-2 focus:ring-primary transition"
                onclick="return confirm('{{ 'confirm_follow_steps'|trans({}, 'config') }}');"
        >
            {{ 'submit'|trans({}, 'config') }}
        </button>

        {{ form_end(form, {'render_rest': false}) }}
    </div>
{% endblock %}

