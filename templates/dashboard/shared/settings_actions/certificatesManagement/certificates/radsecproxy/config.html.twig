{% extends 'dashboard/shared/settings_actions/certificatesManagement/certificates/radsecproxy/base.html.twig' %}

{% block radsecproxy_content %}
    {# Warning message box #}
    <div class="toast-success-dashboard">
        <twig:ux:icon name="wba:info" class="w-10 md:w-5 h-10 md:h-5 inline mr-3 fill-currentColor" />
        <span>
            {{ 'warning.root_command'|trans({}, 'config_radsec') }}
        </span>
    </div>

    {# Update Server Commands #}
    {{ include('dashboard/shared/settings_actions/certificatesManagement/partials/_update_commands.html.twig') }}

    <div class="mt-8 flex justify-end">
        {{ form_start(form) }}
        {{ form_row(form._token) }}

        {% set configApplied = processState.process.radsecproxyConfigAppliedAt is not null %}

        <button
                type="submit"
                class="px-6 py-2.5 rounded-lg shadow font-medium transition
                {% if configApplied %}
                    bg-gray-300 text-gray-700 cursor-not-allowed
                {% else %}
                    bg-primary text-white hover:bg-primary-dark focus:ring-2 focus:ring-offset-2 focus:ring-primary
                {% endif %}"
                {% if configApplied %} disabled title="{{ 'config_already_applied'|trans({}, 'config_radsec') }}" {% else %}
                    onclick="return confirm('{{ 'confirm_follow_steps'|trans({}, 'config_radsec') }}');"
                {% endif %}
        >
            {{ 'submit'|trans({}, 'config_radsec') }}
        </button>
        {{ form_end(form, {render_rest: false}) }}
    </div>
{% endblock %}
