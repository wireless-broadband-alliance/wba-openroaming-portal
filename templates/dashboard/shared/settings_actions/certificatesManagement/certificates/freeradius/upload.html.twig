{% extends 'dashboard/shared/settings_actions/certificatesManagement/certificates/freeradius/base.html.twig' %}

{% block freeradius_content %}
    <div class="toast-success-dashboard m-4 rounded-lg px-6 py-4 shadow">
        <div class="flex flex-col space-y-2">
            <p class="font-semibold text-base">
                {{ 'config.completed'|trans({}, 'config_freeradius') }}
            </p>
            <div class="text-sm">
                <p>
                    {{ 'config.finished_steps'|trans({}, 'config_freeradius') }}
                </p>
                <p>
                    {{ 'config.next_phase'|trans({}, 'config_freeradius') }}
                    <span class="font-semibold">
                        {{ 'config.details'|trans({}, 'config_freeradius') }}
                    </span>
                </p>
            </div>
        </div>
    </div>
{% endblock %}
