{% extends 'dashboard/shared/settings_actions/certificatesManagement/certificates/freeradius/base.html.twig' %}

{% block freeradius_content %}
    {# Manual Test Execution Warning #}
    {{ include('shared/_toast.html.twig', {
        message: 'manual_test_warning'|trans({}, 'test_freeradius'),
        toast_type: 'toast-warning-dashboard',
    }) }}

    <div class="border border-gray-200 rounded-xl shadow-sm overflow-hidden bg-white">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex items-center gap-2">
            <twig:ux:icon class="w-5 h-5 text-primary" name="wba:test-tube-bold"/>
            <h5 class="text-lg font-semibold text-gray-800">
                {{ 'test_and_proceed'|trans({}, 'test_freeradius') }}
            </h5>
        </div>

        <div class="p-6 space-y-6 text-gray-700" data-controller="test-certificates">
            <div class="text-center space-y-3 pt-4">
                <twig:ux:icon name="wba:shield-check" class="w-14 h-14 mx-auto text-primary"/>
                <h3 class="text-gray-900 text-xl font-semibold"
                >
                    {{ 'configuration_complete'|trans({}, 'test_freeradius') }}
                </h3>
                <p class="text-gray-600">
                    {{ 'instructions'|trans({}, 'test_freeradius') }}
                </p>
            </div>

            {# Content #}
            <div class="p-6 mt-6">
                {# Optional Badge for Manual Step #}
                <div class="mb-4">
                <span class="inline-block bg-yellow-100 text-yellow-800 text-xs font-medium px-2 py-1 rounded-full">
                    {{ 'manual_step'|trans({}, 'test_freeradius') }}
                </span>
                </div>

                {# Grid: Command + Textarea #}
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
                    {# Cat Command Block #}
                    <div class="space-y-2" data-controller="clipboard">
                        <p class="text-sm font-medium text-gray-700">
                            {{ 'manual_command_title'|trans({}, 'test_freeradius') }}
                        </p>
                        <div class="relative rounded-md overflow-hidden">
                            <pre class="copyable-code relative rounded bg-gray-800 text-white p-4 font-mono overflow-x-auto whitespace-pre-wrap"
                                 data-clipboard-target="code">cd signing-keys/ && cat ca.pem cert.pem chain.pem fullchain.pem privkey.pem</pre>
                            <button type="button"
                                    class="absolute top-2 right-2 flex items-center justify-center p-1.5 rounded-md bg-gray-700 hover:bg-gray-600 focus:ring-2 focus:ring-primary/50 transition"
                                    title="{{ 'copyCommand.title'|trans({}, 'config_radsec') }}"
                                    aria-label="{{ 'copyCommand.ariaLabel'|trans({}, 'config_radsec') }}"
                                    data-action="click->clipboard#copyToClipboard">
                                <twig:ux:icon class="w-4 h-4 text-white" name="wba:copy"/>
                            </button>
                        </div>
                        <p class="text-xs text-gray-500">
                            {{ 'manual_command_hint'|trans({}, 'test_freeradius') }}
                        </p>
                    </div>

                    {# Textarea for Certificates #}
                    <div class="space-y-2">
                        <label class="block text-sm font-medium text-gray-700">
                            {{ 'paste_certificates_label'|trans({}, 'test_freeradius') }}
                        </label>

                        <label>
                        <textarea
                                name="certificates_content"
                                rows="14"
                                class="form-widget block w-full rounded-md border-gray-200 p-3 font-mono text-sm resize-y shadow-sm focus:ring-2 focus:ring-primary/30 focus:border-primary"
                                placeholder="{{ 'paste_certificates_placeholder'|trans({}, 'test_freeradius') }}"
                        ></textarea>
                        </label>
                    </div>
                </div>
            </div>

            {# Waiting Widget #}
            <div class="mt-6 hidden" data-test-certificates-target="waitingWidget">
                <div class="flex items-center justify-center flex-col gap-4 bg-blue-50 border border-blue-200
            rounded-lg p-6 text-blue-800 text-center animate-fade-in">
                    <div class="animate-spin h-8 w-8 border-4 border-blue-400 border-t-transparent rounded-full"></div>
                    <div>
                        <p class="font-semibold text-blue-900">
                            {{ 'in_progress_title'|trans({}, 'test_freeradius') }}
                        </p>
                        <p class="text-sm text-blue-700">
                            {{ 'in_progress_description'|trans({}, 'test_freeradius') }}
                        </p>
                    </div>
                </div>
            </div>

            {# Result Message #}
            <div class="mt-4 hidden" data-test-certificates-target="resultMessage"></div>

            <div class="flex flex-col items-center gap-6 w-full">
                {# Status #}
                <div class="text-sm flex items-center gap-2 justify-center">
                    {% if process.getFreeradiusTestResult() == constant('App\\Enum\\CertificateTestResult::PASSED') %}
                        <twig:ux:icon name="wba:check-circle-rounded" class="w-5 h-5 text-primary fill-current"/>
                        <span class="text-primary font-medium">
                {{ 'test_passed'|trans({}, 'test_freeradius') }}
            </span>
                    {% elseif process.getFreeradiusTestResult() == constant('App\\Enum\\CertificateTestResult::FAILED') %}
                        <twig:ux:icon name="wba:cross-circle-rounded" class="w-5 h-5 text-red-500"/>
                        <span class="text-red-500">
                {{ 'test_failed'|trans({}, 'test_freeradius') }}
            </span>
                    {% else %}
                        <twig:ux:icon name="wba:cross-circle-rounded" class="w-5 h-5 text-gray-400"/>
                        <span class="text-gray-500">
                {{ 'test_not_done'|trans({}, 'test_freeradius') }}
            </span>
                    {% endif %}
                </div>

                {# Action Buttons #}
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 items-end">
                    {# Run Test #}
                    <button
                            type="button"
                            class="px-6 py-3 bg-primary text-white font-medium rounded-lg shadow hover:bg-primary-dark
                   focus:ring-2 focus:ring-primary/50 transition flex items-center gap-2 w-full md:w-auto justify-center"
                            data-action="click->test-certificates#runTest"
                            data-test-certificates-target="testButton"
                            data-url="{{ path('admin_dashboard_settings_certs_freeradius_test_run') }}"
                    >
                        <twig:ux:icon name="wba:shield-check" class="w-5 h-5"/>
                        <span data-test-certificates-target="buttonLabel">
                {{ 'test_certificates'|trans({}, 'test_freeradius') }}
            </span>
                    </button>
                    {# Next Step #}
                    <a
                            {% if processState.stages.freeradius_test %}
                                href="{{ path('admin_page') }}"
                                data-href-enabled="{{ path('admin_page') }}"
                            {% else %}
                                data-href-enabled="{{ path('admin_page') }}"
                            {% endif %}
                            data-test-certificates-target="nextPageButton"
                            class="px-6 py-3 border border-gray-300 font-medium rounded-lg shadow-sm flex items-center gap-2
                       w-full md:w-auto justify-center
                       {% if not processState.stages.freeradius_test %}
                           bg-gray-100 text-gray-400 cursor-not-allowed pointer-events-none
                       {% else %}
                           bg-white text-gray-800 hover:bg-gray-50 focus:ring-2 focus:ring-primary/30 transition
                       {% endif %}"
                    >
                        <twig:ux:icon name="wba:right" class="w-5 h-5"/>
                        {{ 'finish_configuration'|trans({}, 'test_freeradius') }}
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
