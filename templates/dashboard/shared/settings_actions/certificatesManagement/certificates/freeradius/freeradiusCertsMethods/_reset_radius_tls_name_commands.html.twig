<div
        {{ stimulus_controller('toast') }}
        {{ stimulus_target('toast', 'toast') }}
>
    <div class="toast-warning-dashboard">
        <twig:ux:icon name="wba:info" class="w-5 h-5 inline mr-3 fill-current"/>

        <span class="font-medium flex-1">{{ 'warning'|trans({}, '_reset_radius_tls_name_commands') }}</span>

    </div>
</div>

<div class="border border-gray-200 rounded-xl shadow-sm overflow-hidden mt-6">
    <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex items-center gap-2">
        <twig:ux:icon class="w-5 h-5 text-primary" name="wba:terminal"/>
        <h5 class="text-lg font-semibold text-gray-800">
            {{ 'commandTittle'|trans({}, '_reset_radius_tls_name_commands') }}
        </h5>
    </div>
        <div class="px-6 py-5 space-y-5 bg-white">
            <p class="text-sm font-medium text-gray-700">
                {{ 'description'|trans({}, '_reset_radius_tls_name_commands') }}
            </p>
    {# Command Block #}
        <div class="space-y-2" data-controller="clipboard">
            <div class="relative rounded-md overflow-hidden">
                                    <pre class="copyable-code relative rounded bg-gray-800 text-white p-4 font-mono overflow-x-auto whitespace-pre-wrap"
                                         data-clipboard-target="code">php bin/console reset:radiusTLS</pre>
                <button type="button"
                        class="absolute top-2 right-2 flex items-center justify-center p-1.5 rounded-md bg-gray-700 hover:bg-gray-600 focus:ring-2 focus:ring-primary/50 transition"
                        title="{{ 'copyCommand.title'|trans({}, 'config_radsec') }}"
                        aria-label="{{ 'copyCommand.ariaLabel'|trans({}, 'config_radsec') }}"
                        data-action="click->clipboard#copyToClipboard">
                    <twig:ux:icon class="w-4 h-4 text-white" name="wba:copy"/>
                </button>
            </div>
            {# Warning #}

        </div>
    </div>
</div>
