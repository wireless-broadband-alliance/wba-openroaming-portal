<div class="col-span-full flex flex-col sm:flex-row items-center justify-center gap-4">

    <a href="{{ path('admin_dashboard_settings_certs_radsecproxy_upload') }}"
       data-confirm="{{ 'confirmReinstall'|trans({}, '_certificates') }}"
       class="group inline-flex items-center gap-3 px-8 py-5 rounded-2xl
              bg-primary text-white font-semibold text-lg
              shadow-md transition-all
              hover:shadow-lg hover:scale-[1.02]
              focus:outline-none focus:ring-4 focus:ring-primary/30">

        <twig:ux:icon name="wba:shield-check"
                      class="w-6 h-6 transition-transform group-hover:scale-110" />
        <span>{{ 'renewCertificates'|trans({}, '_certificates') }}</span>
    </a>

    {{ form_start(validateForm, {attr: {class: 'contents'}}) }}
    <button type="submit"
            data-confirm="{{ 'confirmVerifyInstalled'|trans({}, '_certificates') }}"
            class="group inline-flex items-center gap-3 px-8 py-5 rounded-2xl
                   bg-white border border-gray-200 text-gray-700 font-semibold text-lg
                   shadow-md transition-all
                   hover:shadow-lg hover:scale-[1.02] hover:bg-gray-50
                   focus:outline-none focus:ring-4 focus:ring-gray-200">

        <twig:ux:icon name="wba:shield-check"
                      class="w-6 h-6 transition-transform group-hover:scale-110" />
        <span>{{ 'validateExistingCertificates'|trans({}, '_certificates') }}</span>
    </button>
    {{ form_row(validateForm._token) }}
    {{ form_end(validateForm, {render_rest: false}) }}

</div>

{% if lastCompletedCertificates %}
    <p class="col-span-full mt-3 text-center text-sm text-gray-500">
        {{ 'lastCompletedCertificates'|trans({}, '_certificates') }}
        <span class="font-medium text-gray-700">
            {{ lastCompletedCertificates|date('d/m/Y H:i') }}
        </span>
    </p>
{% endif %}

{# --- Validation Results --- #}
{% if certValidationRan %}
    <div class="col-span-full mt-6">
        {% if certValidationErrors is not empty %}
            {# ERRORS — invalid config #}
            <div class="flex items-start gap-3 rounded-xl border border-red-200 bg-red-50 px-5 py-4">
                <twig:ux:icon name="wba:shield-uncheck" class="w-5 h-5 text-red-600 mt-0.5 shrink-0"/>
                <div class="w-full">
                    <p class="font-semibold text-red-800">{{ 'certValidationFailed'|trans({}, '_certificates') }}</p>
                    <ul class="mt-2 space-y-1">
                        {% for error in certValidationErrors %}
                            <li class="text-sm text-red-700 flex items-center gap-2">
                                <span class="w-1.5 h-1.5 rounded-full bg-red-500 shrink-0"></span>
                                {{ error }}
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>

        {% elseif not certIsEv %}
            {# VALID but not EV — warning #}
            <div class="flex items-start gap-3 rounded-xl border border-yellow-200 bg-yellow-50 px-5 py-4">
                <twig:ux:icon name="wba:shield-check" class="w-5 h-5 text-yellow-600 mt-0.5 shrink-0"/>
                <div class="w-full">
                    <p class="font-semibold text-yellow-800">{{ 'certValidationSuccessNotEv'|trans({}, '_certificates') }}</p>
                    <p class="text-sm text-yellow-700 mt-0.5">{{ 'certValidationSuccessNotEvDetail'|trans({}, '_certificates') }}</p>
                    <div class="mt-3 flex items-start gap-2 rounded-lg border border-gray-200 bg-white px-3 py-2">
                        <twig:ux:icon name="wba:info" class="w-4 h-4 text-gray-500 mt-0.5 shrink-0"/>
                        <p class="text-xs text-gray-600">{{ 'certValidationFreeradiusCheck'|trans({}, '_certificates') }}</p>
                    </div>
                </div>
            </div>

        {% else %}
            {# VALID and EV — full success #}
            <div class="flex items-start gap-3 rounded-xl border border-green-200 bg-green-50 px-5 py-4">
                <twig:ux:icon name="wba:shield-check" class="w-5 h-5 text-green-600 mt-0.5 shrink-0"/>
                <div class="w-full">
                    <p class="font-semibold text-green-800">{{ 'certValidationSuccess'|trans({}, '_certificates') }}</p>
                    <p class="text-sm text-green-700 mt-0.5">{{ 'certValidationSuccessDetail'|trans({}, '_certificates') }}</p>
                    <div class="mt-3 flex items-start gap-2 rounded-lg border border-gray-200 bg-white px-3 py-2">
                        <twig:ux:icon name="wba:info" class="w-4 h-4 text-gray-500 mt-0.5 shrink-0"/>
                        <p class="text-xs text-gray-600">{{ 'certValidationFreeradiusCheck'|trans({}, '_certificates') }}</p>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
{% endif %}
