<div class="flex justify-center">
    <a href="{{ path('admin_dashboard_settings_certs_radsecproxy_upload') }}"
       data-confirm="{{ 'confirmReinstall'|trans({}, '_certificates') }}"
       class="group inline-flex items-center gap-4 px-8 py-5 rounded-2xl
              bg-primary text-white font-semibold text-lg
              shadow-md transition-all
              hover:shadow-lg hover:scale-[1.02]
              focus:outline-none focus:ring-4 focus:ring-primary/30">

        <twig:ux:icon name="wba:shield-check"
                      class="w-6 h-6 transition-transform group-hover:scale-110" />

        <span>
            {{ 'renewCertificates'|trans({}, '_certificates') }}
        </span>
    </a>
</div>

{% if lastCompletedCertificates %}
    <p class="mt-3 text-center text-sm text-gray-500">
        {{ 'lastCompletedCertificates'|trans({}, '_certificates') }}
        <span class="font-medium text-gray-700">
            {{ lastCompletedCertificates|date('d/m/Y H:i') }}
        </span>
    </p>
{% endif %}
