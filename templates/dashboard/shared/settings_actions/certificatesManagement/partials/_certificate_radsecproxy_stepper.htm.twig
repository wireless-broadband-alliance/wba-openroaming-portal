{% set steps = [
    {id: 'radsecproxy_upload', route: 'admin_dashboard_settings_certs_radsecproxy_upload'},
    {id: 'radsecproxy_config', route: 'admin_dashboard_settings_certs_radsecproxy_config'},
    {id: 'radsecproxy_test', route: 'admin_dashboard_settings_certs_radsecproxy_test'},
] %}

{% set currentRoute = app.request.attributes.get('_route') %}
{% set currentIndex = 0 %}

{% for s in steps %}
    {% if s.route == currentRoute %}
        {% set currentIndex = loop.index0 %}
    {% endif %}
{% endfor %}

<div class="w-full max-w-5xl mx-auto mt-8 mb-10 px-4">
    <div {{ stimulus_controller('card') }}>
        <div class="btn-primary"
                {{ stimulus_target('card', 'button') }}
                {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
        >
            Hover me
        </div>

        <div class="toast-light-warning mb-6 hidden opacity-0 transition-opacity duration-300 mt-3"
                {{ stimulus_target('card', 'info') }}>
            <twig:ux:icon name="wba:info" class="w-10 md:w-5 h-10 md:h-5 inline mr-3 fill-current"/>
            <span>
            Please note that you can use the numbered circles to navigate between completed steps.
            You can only access steps that have already been completed.
        </span>
        </div>
    </div>

    <div class="relative flex flex-col md:flex-row items-start md:items-center md:justify-between">
        {# Progress bar #}
        <div class="hidden md:block absolute top-1/2 left-0 h-1 bg-primary rounded-full transform -translate-y-1/2 transition-all duration-500 ease-in-out"
             style="width: calc({{ ((currentIndex + 1) / steps|length) * 100 }}%)"
        ></div>

        {# Steps #}
        {% set stages = processState.stages ?? {} %}

        {% for step in steps %}
            {% set title = ('step.' ~ step.id ~ '.title')|trans(domain: '_certificate_stepper') %}
            {% set description = ('step.' ~ step.id ~ '.description')|trans(domain: '_certificate_stepper') %}
            {% set index = loop.index0 %}
            {% set active = step.route == currentRoute %}
            {% set completed = stages[step.id] ?? false %}
            {% set previousCompleted = index == 0 or (steps[index - 1].id in stages and stages[steps[index - 1].id]) %}

            <div class="w-full md:flex-1 flex flex-col md:items-center text-center mb-8 p-2">
                <div class="flex items-center justify-center w-10 h-10 sm:w-9 sm:h-9 rounded-full border-2 z-10 font-semibold transition-all duration-300 text-center
                    {% if completed %} bg-primary border-primary text-white
                    {% elseif active %} bg-white border-primary text-primary step-active
                    {% else %} bg-white border-gray-300 text-gray-400 {% endif %}
                ">
                    {% if loop.first %}
                        {# Step 1 (Upload): always clickable via abort form #}
                        <form action="{{ path('admin_dashboard_settings_certs_management_abort') }}" method="POST"
                              class="w-full h-full">
                            <button type="submit"
                                    class="flex items-center justify-center w-full h-full text-inherit bg-transparent border-none p-0 m-0 cursor-pointer leading-none"
                                    onclick="return confirm('{{ 'confirm_abort'|trans({}, '_certificate_stepper') }}');">
                                {{ loop.index }}
                            </button>
                        </form>
                    {% else %}
                        {# Allow click only if previous step is completed #}
                        {% if previousCompleted %}
                            <a href="{{ path(step.route) }}"
                               class="flex items-center justify-center w-full h-full text-inherit no-underline leading-none">
                                {{ loop.index }}
                            </a>
                        {% else %}
                            <span class="flex items-center justify-center w-full h-full cursor-not-allowed opacity-50 leading-none">
                                {{ loop.index }}
                            </span>
                        {% endif %}
                    {% endif %}
                </div>

                <div class="mt-2 sm:mt-1 md:mt-2">
                    <h4 class="text-sm sm:text-xs font-semibold
                        {% if completed or active %} text-primary {% else %} text-gray-500 {% endif %}">
                        {{ title }}
                    </h4>
                    <p class="text-xs sm:text-[9px] text-gray-400 mt-1 break-words">{{ description }}</p>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Abort button (POST only) #}
    {% if processState is defined and processState.active %}
        <div class="mt-8 flex justify-end">
            <form action="{{ path('admin_dashboard_settings_certs_management_abort') }}" method="POST"
                  onsubmit="return confirm('{{ 'confirm_abort'|trans({}, '_certificate_stepper') }}');">
                <button type="submit" class="btn-logout flex items-center gap-2">
                    {{ 'abort'|trans({}, '_certificate_stepper') }}
                </button>
            </form>
        </div>
    {% endif %}
</div>
