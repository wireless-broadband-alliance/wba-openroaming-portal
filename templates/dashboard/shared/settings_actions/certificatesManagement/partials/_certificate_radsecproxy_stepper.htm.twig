{% set steps = [
    { id: 'radsecproxy_upload' },
    { id: 'radsecproxy_config' },
    { id: 'radsecproxy_completed' }
] %}

{% set currentStage = processState.stage ?? 'radsecproxy_upload' %}
{% set currentIndex = 0 %}
{% for s in steps %}
    {% if s.id == currentStage %}
        {% set currentIndex = loop.index0 %}
    {% endif %}
{% endfor %}

<div class="w-full max-w-5xl mx-auto mt-8 mb-10 px-4">
    <div class="relative flex items-center justify-between">
        {# Background line #}
        <div class="absolute top-1/2 left-0 w-full h-1 bg-gray-200 rounded-full transform -translate-y-1/2"></div>

        {# Progress bar fill — use primary color #}
        <div
                class="absolute top-1/2 left-0 h-1 bg-primary rounded-full transform -translate-y-1/2 transition-all duration-500 ease-in-out"
                style="width: calc({{ ((currentIndex + 1) / steps|length) * 100 }}%)"
        ></div>

        {# Step circles and labels #}
        {% for step in steps %}
            {% set title = ('step.' ~ step.id ~ '.title')|trans(domain='_certificate_stepper') %}
            {% set description = ('step.' ~ step.id ~ '.description')|trans(domain='_certificate_stepper') %}
            {% set index = loop.index0 %}
            {% set active = step.id == currentStage %}
            {% set completed = index < currentIndex %}

            <div class="relative flex flex-col items-center text-center w-1/3">
                <div
                        class="flex items-center justify-center w-10 h-10 rounded-full border-2 z-10 font-semibold transition-all duration-300
                        {% if completed %}
                            bg-primary border-primary text-white
                        {% elseif active %}
                            bg-white border-primary text-primary
                        {% else %}
                            bg-white border-gray-300 text-gray-400
                        {% endif %}
                    ">
                    {{ loop.index }}
                </div>

                <div class="mt-3">
                    <h4 class="text-sm font-semibold
                        {% if completed or active %}
                            text-primary
                        {% else %}
                            text-gray-500
                        {% endif %}
                    ">
                        {{ title }}
                    </h4>
                    <p class="text-xs text-gray-400 mt-1">{{ description }}</p>
                </div>
            </div>
        {% endfor %}
    </div>

    {# Abort button (only visible if there’s an active process) #}
    {% if processState is defined and processState.active %}
        <div class="mt-8 flex justify-end">
            <a href="{{ path('admin_dashboard_settings_certs_management_abort') }}"
               class="btn-logout flex items-center gap-2"
               onclick="return confirm('{{ 'confirm_abort'|trans({}, '_certificate_stepper') }}');">
                <twig:ux:icon name="wba:cross" class="w-5 h-5" />
                {{ 'abort'|trans({}, '_certificate_stepper') }}
            </a>
        </div>
    {% endif %}
</div>
