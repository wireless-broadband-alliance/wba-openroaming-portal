{% if commands is defined and commands is not empty %}
    <div class="border border-gray-200 rounded-xl shadow-sm overflow-hidden mt-6">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200 flex items-center gap-2">
            <twig:ux:icon class="w-5 h-5 text-primary" name="wba:terminal"/>
            <h5 class="text-lg font-semibold text-gray-800">
                {{ title|default('Update Server Commands')|trans({}, 'config_radsec') }}
            </h5>
        </div>

        <div class="px-6 py-5 space-y-5 bg-white">
            {% for step in commands %}
                {% set isSensitive = step.command matches '/key\\.pem/' %}
                <div class="space-y-2 relative" data-controller="clipboard">
                    {# Step description #}
                    <p class="text-sm font-medium text-gray-700">
                        {{ 'step'|trans({}, 'config_radsec') }} {{ loop.index }} – {{ step.description }}
                    </p>

                    {% if isSensitive %}
                        <div data-controller="command-visibility" class="relative">
                            {# Toggle button #}
                            <button type="button"
                                    class="mt-1 mb-2 text-sm text-primary underline"
                                    data-action="command-visibility#toggle">
                                {{ 'show_sensitive'|trans({}, 'config_radsec') }}
                            </button>

                            {# Hidden Block (Blurred but copyable) #}
                            <div data-command-visibility-target="hiddenBlock"
                                 class="relative rounded bg-gray-800 text-gray-300 p-4 font-mono">
                                {# Copy button #}
                                <pre class="copyable-code relative rounded text-gray-300 blur-sm select-text overflow-x-auto"
                                     data-clipboard-target="code">{{ step.command|raw }}</pre>
                                {{ include('shared/_copy_button.html.twig') }}
                            </div>

                            {# Revealed Block #}
                            <div data-command-visibility-target="visibleBlock"
                                 class="hidden relative rounded bg-gray-800 text-white font-mono">
                                {# Copy button #}
                                <pre class="copyable-code relative rounded bg-gray-800 text-white p-4 font-mono overflow-x-auto"
                                     data-clipboard-target="code">{{ step.command|raw }}</pre>
                                <button type="button"
                                        class="absolute top-2 right-2 flex items-center justify-center p-1.5 rounded-md bg-gray-700 hover:bg-gray-600 focus:ring-2 focus:ring-primary/50 transition"
                                        title="{{ 'copy_command.title'|trans({}, 'config_radsec') }}"
                                        aria-label="{{ 'copy_command.aria_label'|trans({}, 'config_radsec') }}"
                                        data-action="click->clipboard#copyToClipboard">
                                    <twig:ux:icon class="w-4 h-4 text-white" name="wba:copy"/>
                                </button>
                            </div>
                        </div>
                    {% else %}
                        <div class="relative">
                            <pre class="copyable-code relative rounded bg-gray-800 text-white p-4 font-mono overflow-x-auto"
                                 data-clipboard-target="code">{{ step.command|raw }}</pre>
                            <button type="button"
                                    class="absolute top-2 right-2 flex items-center justify-center p-1.5 rounded-md bg-gray-700 hover:bg-gray-600 focus:ring-2 focus:ring-primary/50 transition"
                                    title="{{ 'copy_command.title'|trans({}, 'config_radsec') }}"
                                    aria-label="{{ 'copy_command.aria_label'|trans({}, 'config_radsec') }}"
                                    data-action="click->clipboard#copyToClipboard">
                                <twig:ux:icon class="w-4 h-4 text-white" name="wba:copy"/>
                            </button>
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
