{% set setupProcessType = app.session.get('freeradiusSetupProcessType') %}

{% set steps = [
    {
        id: 'freeradius_upload',
        routes: [
        'admin_dashboard_settings_certs_freeradius_upload',
        'admin_dashboard_settings_certs_freeradius_auto_renew',
        'admin_dashboard_settings_certs_freeradius_auto_renew_domain',
    ],
    },
    {
        id: 'freeradius_config',
        routes: ['admin_dashboard_settings_certs_freeradius_config'],
    },
    {
        id: 'freeradius_test',
        routes: ['admin_dashboard_settings_certs_freeradius_test'],
    },
] %}

{% set currentRoute = app.request.attributes.get('_route') %}
{% set currentIndex = 0 %}

{% for s in steps %}
    {% if currentRoute in s.routes %}
        {% set currentIndex = loop.index0 %}
    {% endif %}
{% endfor %}

{{ include('dashboard/shared/settings_actions/certificatesManagement/partials/_abort_certs.html.twig') }}

<div class="w-full max-w-5xl mx-auto mt-8 mb-10 px-4">
    <div class="p-2">
        {{ include('dashboard/shared/_info_details.html.twig', {
            info_text: 'info_text_stepper_details'|trans({}, '_certificate_stepper'),
        }) }}
    </div>

    <div class="relative flex flex-col md:flex-row items-start md:items-center">

        {# Progress bar #}
        <div class="hidden md:block absolute top-1/2 left-0 h-1 rounded-full transform -translate-y-1/2 transition-all duration-500 ease-in-out"
             style="width: calc({{ ((currentIndex + 1) / steps|length) * 100 }}%)"
        ></div>

        {% set stages = processState.stages ?? {} %}

        {% for step in steps %}
            {% set title = ('step.' ~ step.id ~ '.title')|trans(domain: '_certificate_stepper') %}
            {% set description = ('step.' ~ step.id ~ '.description')|trans(domain: '_certificate_stepper') %}
            {% set index = loop.index0 %}
            {% set active = currentRoute in step.routes %}
            {% set completed = stages[step.id] ?? false %}
            {% set previousCompleted = index == 0 or (steps[index - 1].id in stages and stages[steps[index - 1].id]) %}

            {# 🔹 Compute stepRoute dynamically #}
            {% set stepRoute = step.routes[0] %}
            {% if step.id == 'freeradius_upload' %}
                {% if setupProcessType == constant('App\\Enum\\AnalyticalEventType::CERTIFICATE_SETUP_PROCESS_FREERAEDIUS_UPLOAD_AUTO_DOMAIN').value %}
                    {% set stepRoute = 'admin_dashboard_settings_certs_freeradius_auto_renew_domain' %}
                {% else %}
                    {% set stepRoute = 'admin_dashboard_settings_certs_freeradius_upload' %}
                {% endif %}
            {% endif %}

            <div class="w-full md:flex-1 flex flex-col md:items-center text-center mb-8 p-2">
                <div class="
                    flex items-center justify-center w-10 h-10 rounded-full border-2 z-10 font-semibold
                    transition-all duration-300 text-center
                    {% if completed %} bg-primary border-primary text-white
                    {% elseif active %} bg-white border-primary text-primary step-active
                    {% else %} bg-white border-gray-300 text-gray-400 {% endif %}
                ">
                    {% if previousCompleted %}
                        <a href="{{ path(stepRoute) }}"
                           class="flex items-center justify-center w-full h-full text-inherit no-underline leading-none">
                            {{ loop.index }}
                        </a>
                    {% else %}
                        <span class="flex items-center justify-center w-full h-full cursor-not-allowed opacity-50 leading-none">
                            {{ loop.index }}
                        </span>
                    {% endif %}
                </div>

                <div class="mt-4 sm:mt-1 md:mt-2">
                    <h4 class="text-sm sm:text-xs font-semibold
                        {% if completed or active %} text-primary {% else %} text-gray-500 {% endif %}
                    ">
                        {{ title }}
                    </h4>
                    <p class="text-xs sm:text-[9px] text-gray-400 mt-1 break-words">
                        {{ description }}
                    </p>
                </div>
            </div>

        {% endfor %}
    </div>
</div>
