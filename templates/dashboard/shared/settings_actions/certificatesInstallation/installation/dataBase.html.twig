{% set bgUrl = data.WALLPAPER_IMAGE.value != '/resources/images/wallpaper.png'
    ? data.WALLPAPER_IMAGE.value
    : '/resources/images/background.png' %}

{% extends 'landing/authUser/base.html.twig' %}

{% block title %}
    {{ data.PAGE_TITLE.value }}
{% endblock %}

{% block content %}

    {{ block('toast_messages') }}

    <div class="mt-6 leading-7">
        <p class="font-bold text-base sm:text-lg md:text-xl lg:text-2xl">
            {{ 'databaseTitle'|trans({}, 'dataBase') }}
        </p>
        <p class="mt-3 text-sm sm:text-base md:text-lg lg:text-xl text-gray-600">
            {{ 'databaseDescription'|trans({}, 'dataBase') }}
        </p>
    </div>

    <div class="my-[25px] divider"></div>

    {# OpenRoaming & Freeradius Section #}
    <div class="w-full">
        {{ form_start(form, { action: path('app_landing_account_user') }) }}
        {{ form_errors(form) }}

        <div class="flex flex-col gap-y-8">
            <div class="relative w-full">
                {{ form_label(form.dbOpenRoaming, 'dbOpenRoamingLabel'|trans({}, 'dataBase'), {
                    label_attr: { class: 'form-label' }
                }) }}
                {{ form_widget(form.dbOpenRoaming, {
                    attr: {
                        class: 'form-widget w-full',
                        minlength: 7
                    }
                }) }}
                {{ form_errors(form.dbOpenRoaming) }}
            </div>

            <div class="relative w-full">
                {{ form_label(form.dbFreeradius, 'dbFreeradiusLabel'|trans({}, 'dataBase'), {
                    label_attr: { class: 'form-label' }
                }) }}
                {{ form_widget(form.dbFreeradius, {
                    attr: {
                        class: 'form-widget w-full',
                        minlength: 7
                    }
                }) }}
                {{ form_errors(form.dbFreeradius) }}
            </div>
        </div>

        <button class="mt-6 w-full md:w-[180px] btn-primary"
                type="submit">
            {{ 'databaseApplyBtn'|trans({}, 'dataBase') }}
        </button>

        {{ form_rest(form) }}
        {{ form_end(form) }}
    </div>

{% endblock %}