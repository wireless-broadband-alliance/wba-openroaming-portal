<twig:SMSSettingsForm
        :SMSSettingsDTO="SMSSettingsDTO"
        :data="data"
        :form="form">

    {{ form_start(form) }}
    {{ form_widget(form._token) }}

    <div class="grid gap-4 lg:grid-cols-2 xl:grid-cols-3 p-2 z-0">

        {# SMS_USERNAME #}
        <div class="transition hover:-translate-y-1 hover:shadow bg-white rounded-md p-6 w-full" {{ stimulus_controller('card') }}>
            <div class="flex flex-row justify-between">
                <div class="text-base font-medium text-center break-normal md:break-all">
                    <h1 class="text-base md:text-lg whitespace-nowrap">{{ 'username'|trans({}, '_sms') }}</h1>
                </div>
                <label class="flex items-center bg-opacity-40">
                    <img class="w-6 cursor-pointer" {{ stimulus_target('card', 'button') }} {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
                         src="{{ asset('resources/logos/info_icon.svg') }}" alt="info_icon"/>
                </label>
            </div>
            {{ include('/dashboard/shared/settings_actions/_description.html.twig', {description: data.SMS_USERNAME.description}) }}
            <div class="flex items-center space-x-2 mt-5">
                {{ form_widget(form.smsUsername, {attr: {class: 'form-widget'}}) }}
            </div>
            <div class="mt-2 -mb-2 text-center text-red-500 text-base">
                {{ form_errors(form.smsUsername) }}
            </div>
        </div>

        {# SMS_USER_ID #}
        <div class="transition hover:-translate-y-1 hover:shadow bg-white rounded-md p-6 w-full" {{ stimulus_controller('card') }}>
            <div class="flex flex-row justify-between">
                <div class="text-base font-medium text-center break-normal md:break-all">
                    <h1 class="text-base md:text-lg whitespace-nowrap">{{ 'userId'|trans({}, '_sms') }}</h1>
                </div>
                <label class="flex items-center bg-opacity-40">
                    <img class="w-6 cursor-pointer" {{ stimulus_target('card', 'button') }} {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
                         src="{{ asset('resources/logos/info_icon.svg') }}" alt="info_icon"/>
                </label>
            </div>
            {{ include('/dashboard/shared/settings_actions/_description.html.twig', {description: data.SMS_USER_ID.description}) }}
            <div class="flex items-center space-x-2 mt-5">
                {{ form_widget(form.smsUserId, {attr: {class: 'form-widget', autocomplete: 'off'}}) }}
            </div>
            <div class="mt-2 -mb-2 text-center text-red-500 text-base">
                {{ form_errors(form.smsUserId) }}
            </div>
        </div>

        {# SMS_HANDLE #}
        <div class="transition hover:-translate-y-1 hover:shadow bg-white rounded-md p-6 w-full" {{ stimulus_controller('card') }}>
            <div class="flex flex-row justify-between">
                <div class="text-base font-medium text-center break-normal md:break-all">
                    <h1 class="text-base md:text-lg whitespace-nowrap">{{ 'handle'|trans({}, '_sms') }}</h1>
                </div>
                <label class="flex items-center bg-opacity-40">
                    <img class="w-6 cursor-pointer" {{ stimulus_target('card', 'button') }} {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
                         src="{{ asset('resources/logos/info_icon.svg') }}" alt="info_icon"/>
                </label>
            </div>
            {{ include('/dashboard/shared/settings_actions/_description.html.twig', {description: data.SMS_HANDLE.description}) }}
            <div class="flex items-center space-x-2 mt-5">
                {{ form_widget(form.smsHandle, {attr: {class: 'form-widget', autocomplete: 'off'}}) }}
            </div>
            <div class="mt-2 -mb-2 text-center text-red-500 text-base">
                {{ form_errors(form.smsHandle) }}
            </div>
        </div>

        {# SMS_FROM #}
        <div class="transition hover:-translate-y-1 hover:shadow bg-white rounded-md p-6 w-full" {{ stimulus_controller('card') }}>
            <div class="flex flex-row justify-between">
                <div class="text-base font-medium text-center break-normal md:break-all">
                    <h1 class="text-base md:text-lg whitespace-nowrap">{{ 'from'|trans({}, '_sms') }}</h1>
                </div>
                <label class="flex items-center bg-opacity-40">
                    <img class="w-6 cursor-pointer" {{ stimulus_target('card', 'button') }} {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
                         src="{{ asset('resources/logos/info_icon.svg') }}" alt="info_icon"/>
                </label>
            </div>
            {{ include('/dashboard/shared/settings_actions/_description.html.twig', {description: data.SMS_FROM.description}) }}
            <div class="flex items-center space-x-2 mt-5">
                {{ form_widget(form.smsFrom, {attr: {class: 'form-widget'}}) }}
            </div>
            <div class="mt-2 -mb-2 text-center text-red-500 text-base">
                {{ form_errors(form.smsFrom) }}
            </div>
        </div>

        {# SMS_TIMER_RESEND #}
        <div class="transition hover:-translate-y-1 hover:shadow bg-white rounded-md p-6 w-full" {{ stimulus_controller('card') }}>
            <div class="flex flex-row justify-between">
                <div class="text-base font-medium text-center break-normal md:break-all">
                    <h1 class="text-base md:text-lg whitespace-nowrap">{{ 'timeToResend'|trans({}, '_sms') }}</h1>
                </div>
                <label class="flex items-center bg-opacity-40">
                    <img class="w-6 cursor-pointer" {{ stimulus_target('card', 'button') }} {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
                         src="{{ asset('resources/logos/info_icon.svg') }}" alt="info_icon"/>
                </label>
            </div>

            {{ include('/dashboard/shared/settings_actions/_description.html.twig', {description: data.SMS_TIMER_RESEND.description}) }}

            <div class="flex items-center space-x-2 mt-5">
                {{ form_widget(form.smsTimerResend, {attr: {class: 'form-widget', autocomplete: 'off'}}) }}
            </div>
            <div class="mt-2 -mb-2 text-center text-red-500 text-base">
                {{ form_errors(form.smsTimerResend) }}
            </div>
        </div>

        {# DEFAULT_REGION_PHONE_INPUTS #}
        <div class="transition hover:-translate-y-1 hover:shadow bg-white rounded-md p-6 w-full" {{ stimulus_controller('card') }}>
            <div class="flex flex-row justify-between">
                <div class="text-base font-medium text-center break-normal md:break-all">
                    <h1 class="text-base md:text-lg whitespace-nowrap">{{ 'defaultRegionPhoneInputs'|trans({}, '_sms') }}</h1>
                </div>
                <label class="flex items-center bg-opacity-40">
                    <img class="w-6 cursor-pointer" {{ stimulus_target('card', 'button') }} {{ stimulus_action('card', 'show_info', 'mouseover')|stimulus_action('card', 'hide_info', 'mouseout') }}
                         src="{{ asset('resources/logos/info_icon.svg') }}" alt="info_icon"/>
                </label>
            </div>

            {{ include('/dashboard/shared/settings_actions/_description.html.twig', {description: data.DEFAULT_REGION_PHONE_INPUTS.description}) }}

            <div class="flex items-center space-x-2 mt-5">
                {{ form_widget(form.defaultRegionPhoneInputs, {attr: {class: 'form-widget-selector'}}) }}
            </div>
            <div class="mt-2 -mb-2 text-center text-red-500 text-base">
                {{ form_errors(form.defaultRegionPhoneInputs) }}
            </div>
        </div>
    </div>

    <div class="mt-2 mr-2 p-2 z-0 text-base font-semibold w-full">
        <div class="flex bg-infoBgColor/50 rounded-lg p-4 text-xs md:text-sm text-infoTextColor" role="alert">
            <twig:ux:icon name="wba:info" class="w-10 md:w-5 h-10 md:h-5 inline mr-3 fill-current"/>
            <span class="font-medium">
                {{ 'sms_provider_notice'|trans({}, '_sms')|raw }}
            </span>
        </div>
    </div>

    <div class="mt-8 divider-solid"></div>

    {% if is_granted(constant('App\\Security\\Voter\\UserAuthenticationVoter::SMS_CONFIG_WRITE')) %}
        <div class="mt-6 flex flex-row w-full justify-end items-center gap-2">
            <a href="{{ path('app_dashboard_regenerate_code_admin', {type: 'settingRadius'}) }}"
               onclick="return confirm('{{ 'resetMessage'|trans({}, 'settings_actions_general') }}')"
               class="text-sm hover:text-red-600 font-bold p-2 rounded-lg transition ease-in duration-300">
                {{ 'reset'|trans({}, 'settings_actions_general') }}
            </a>

            <button type="submit" class="btn-primary"
                    onclick="return confirm('{{ 'saveChangesMessage'|trans({}, 'settings_actions_general') }}')">
                {{ 'saveChanges'|trans({}, 'settings_actions_general') }}
            </button>
        </div>
    {% endif %}

    {{ form_rest(form) }}
    {{ form_end(form, {render_rest: false}) }}
</twig:SMSSettingsForm>
