<div
        data-domain-blacklist-target="modal"
        class="hidden p-4 fixed inset-0 bg-black/40 sm:bg-black/50 lg:bg-black/60 flex items-center justify-center z-50 transition-opacity duration-300"
        data-action="click->domain-blacklist#close"
>
    <div
            data-domain-blacklist-target="modalInner"
            class="relative w-full sm:w-11/12 md:max-w-2xl lg:max-w-3xl xl:max-w-4xl max-h-[90vh] bg-white rounded-xl shadow-xl flex flex-col transform scale-95 opacity-0 transition-all duration-300"
            data-action="click->domain-blacklist#stop"
    >
        {# Header #}
        <div class="flex justify-between items-center border-b p-4">
            <h2 class="text-primary text-lg font-semibold" data-domain-blacklist-target="title">
                {{ 'editDomain'|trans({}, '_blacklist') }}
            </h2>
            <button
                    type="button"
                    class="flex items-center gap-x-2 text-[#707070] hover:text-primary transition"
                    data-action="domain-blacklist#close"
            >
                <span>{{ 'close'|trans({}, '_blacklist') }}</span>
                <twig:ux:icon name="wba:cross" class="fill-current"/>
            </button>
        </div>

        {# Form container #}
        <div
                data-domain-blacklist-target="content"
                class="flex-1 overflow-y-auto px-4 py-6 sm:px-6 md:px-8 lg:px-10"
        >
            {# Form will be loaded dynamically via Stimulus #}
        </div>
    </div>
</div>
