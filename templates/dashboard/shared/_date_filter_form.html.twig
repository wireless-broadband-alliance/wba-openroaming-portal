<div data-controller="date-filter"
     data-date-filter-active-preset-value="{{ activePreset }}"
     data-date-filter-translations-value="{{ {
         maxRangeError: 'maxRangeError'|trans({}, '_date_filter'),
         maxRangeHint: 'maxRangeHint'|trans({}, '_date_filter'),
         selectStart: 'selectStart'|trans({}, '_date_filter'),
         selectEnd: 'selectEnd'|trans({}, '_date_filter'),
         selected: 'selected'|trans({}, '_date_filter'),
         selectedDay: 'selectedDay'|trans({}, '_date_filter'),
         selectedDays: 'selectedDays'|trans({}, '_date_filter'),
         pickRange: 'pickRange'|trans({}, '_date_filter'),
         daySu: 'daySu'|trans({}, '_date_filter'),
         dayMo: 'dayMo'|trans({}, '_date_filter'),
         dayTu: 'dayTu'|trans({}, '_date_filter'),
         dayWe: 'dayWe'|trans({}, '_date_filter'),
         dayTh: 'dayTh'|trans({}, '_date_filter'),
         dayFr: 'dayFr'|trans({}, '_date_filter'),
         daySa: 'daySa'|trans({}, '_date_filter'),
         monthJan: 'monthJan'|trans({}, '_date_filter'),
         monthFeb: 'monthFeb'|trans({}, '_date_filter'),
         monthMar: 'monthMar'|trans({}, '_date_filter'),
         monthApr: 'monthApr'|trans({}, '_date_filter'),
         monthMay: 'monthMay'|trans({}, '_date_filter'),
         monthJun: 'monthJun'|trans({}, '_date_filter'),
         monthJul: 'monthJul'|trans({}, '_date_filter'),
         monthAug: 'monthAug'|trans({}, '_date_filter'),
         monthSep: 'monthSep'|trans({}, '_date_filter'),
         monthOct: 'monthOct'|trans({}, '_date_filter'),
         monthNov: 'monthNov'|trans({}, '_date_filter'),
         monthDec: 'monthDec'|trans({}, '_date_filter'),
     }|json_encode }}"
     class="flex items-center gap-2 flex-wrap">

    {# Hidden inputs — must be outside any hidden element so Stimulus can always find them #}
    <input type="hidden" name="preset" data-date-filter-target="presetInput" value="{{ activePreset }}">
    <input type="hidden" name="startDate" data-date-filter-target="start" value="{{ selectedStartDate }}">
    <input type="hidden" name="endDate" data-date-filter-target="end" value="{{ selectedEndDate }}">

    {# Preset pill group #}
    <div class="flex items-center gap-1 bg-gray-100 rounded-lg p-[3px]">
        <button type="button"
                data-date-filter-target="presetBtn"
                data-action="click->date-filter#applyPreset"
                data-value="yesterday"
                class="preset-btn px-3 py-[5px] rounded-md text-sm text-gray-500 hover:bg-white hover:text-gray-800 transition-all duration-150">
            {{ 'yesterday'|trans({}, '_date_filter') }}
        </button>
        <button type="button"
                data-date-filter-target="presetBtn"
                data-action="click->date-filter#applyPreset"
                data-value="7d"
                class="preset-btn px-3 py-[5px] rounded-md text-sm text-gray-500 hover:bg-white hover:text-gray-800 transition-all duration-150">
            {{ 'last7Days'|trans({}, '_date_filter') }}
        </button>
        <button type="button"
                data-date-filter-target="presetBtn"
                data-action="click->date-filter#applyPreset"
                data-value="30d"
                class="preset-btn px-3 py-[5px] rounded-md text-sm text-gray-500 hover:bg-white hover:text-gray-800 transition-all duration-150">
            {{ 'last30Days'|trans({}, '_date_filter') }}
        </button>
        <button type="button"
                data-date-filter-target="presetBtn"
                data-action="click->date-filter#applyPreset"
                data-value="1m"
                class="preset-btn px-3 py-[5px] rounded-md text-sm text-gray-500 hover:bg-white hover:text-gray-800 transition-all duration-150">
            {{ 'lastMonth'|trans({}, '_date_filter') }}
        </button>
        <button type="button"
                data-date-filter-target="presetBtn"
                data-action="click->date-filter#applyPreset"
                data-value="custom"
                class="preset-btn px-3 py-[5px] rounded-md text-sm text-gray-500 hover:bg-white hover:text-gray-800 transition-all duration-150">
            {{ 'custom'|trans({}, '_date_filter') }}
        </button>
    </div>

    {# Custom date picker — shown only when Custom is active #}
    <div data-date-filter-target="customPicker"
         class="hidden items-center gap-2">
        <div class="sep w-px h-5 bg-gray-200"></div>

        <div class="relative" data-date-filter-target="pickerWrap">
            <button type="button"
                    data-action="click->date-filter#togglePicker"
                    data-date-filter-target="pickerTrigger"
                    class="flex items-center gap-2 border border-gray-300 rounded-md px-3 py-[5px] text-sm bg-white hover:border-[#7DB928] transition-colors">
                <svg class="w-3.5 h-3.5 text-gray-400" viewBox="0 0 16 16" fill="none" stroke="currentColor"
                     stroke-width="1.5">
                    <rect x="1.5" y="3" width="13" height="11" rx="2" />
                    <path d="M5 1v4M11 1v4M1.5 7h13" />
                </svg>
                <span data-date-filter-target="rangeLabel" class="text-gray-500 text-xs">
                    {% if selectedStartDate and selectedEndDate %}
                        <span class="text-gray-800 font-medium">{{ selectedStartDate|date('d M Y') }}</span>
                        → <span class="text-gray-800 font-medium">{{ selectedEndDate|date('d M Y') }}</span>
                    {% else %}
                        Pick a range
                    {% endif %}
                </span>
                <span data-date-filter-target="pickerArrow" class="text-[10px] text-gray-400">▼</span>
            </button>

            {# Dropdown #}
            <div data-date-filter-target="pickerDropdown"
                 class="hidden absolute right-0 top-full mt-2 z-50 bg-white border border-gray-200 rounded-xl p-4 shadow-lg w-[580px]">

                <div class="grid grid-cols-2 gap-4" data-date-filter-target="calendarGrid"></div>

                <div class="flex items-center justify-between border-t border-gray-100 pt-3 mt-3">
                    <span data-date-filter-target="footerSummary" class="text-xs text-gray-500"></span>
                    <div class="flex gap-2">
                        <button type="button"
                                data-action="click->date-filter#clearRange"
                                class="text-xs border border-gray-200 rounded-md px-3 py-1.5 text-gray-500 hover:border-gray-400 hover:text-gray-700 transition-colors">
                            {{ 'clear'|trans({}, '_date_filter') }}
                        </button>
                        <button type="button"
                                data-action="click->date-filter#applyCustomRange"
                                class="text-xs bg-[#7DB928] text-white rounded-md px-4 py-1.5 font-medium hover:opacity-90 transition-opacity">
                            {{ 'applyRange'|trans({}, '_date_filter') }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
