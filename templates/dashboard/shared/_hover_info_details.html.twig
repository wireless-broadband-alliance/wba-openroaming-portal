<div {{ stimulus_controller('nav-dropdown') }} class="relative inline-block mb-8">
    {# Clickable circle button #}
    <div
            {{ stimulus_target('nav-dropdown', 'button') }}
            {{ stimulus_action('nav-dropdown', 'toggle', 'click') }}
            class="relative flex items-center justify-center w-12 h-12 md:w-8 md:h-8 rounded-full bg-blue-100 text-blue-600
               shadow-sm transition-all duration-300 hover:bg-blue-200 hover:text-blue-700 hover:shadow-md cursor-pointer"
    >
        <twig:ux:icon name="wba:info" class="w-6 h-6 md:w-5 md:h-5 fill-current" />
        {# Tooltip (optional) #}
        <span class="absolute bottom-full mb-2 px-3 py-1.5 text-xs text-white bg-blue-600 rounded-md opacity-0
                     group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
            More info
        </span>
    </div>

    {# Info message block #}
    <div
            {{ stimulus_target('nav-dropdown', 'container') }}
            class="absolute left-full top-1/2 ml-3 -translate-y-1/2 p-3 rounded-lg bg-yellow-50 text-yellow-800
               flex items-start gap-3 shadow-sm transition-opacity duration-300 w-max z-10 hidden opacity-0"
    >
        <span class="text-yellow-800 bg-yellow-50 px-3 py-2 rounded-lg shadow-sm">{{ info_text|raw }}</span>
    </div>
</div>
