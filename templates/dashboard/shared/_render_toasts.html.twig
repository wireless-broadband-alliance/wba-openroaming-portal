<div class="grid grid-cols-1 gap-[5px] my-3 p-3">
    {# Error Toasts Dashboard #}
    {% for message in app.session.flashbag.get('error_admin') %}
        {{ include('dashboard/shared/_toast.html.twig', {
            toast_type: 'toast-error',
            message: message
        }) }}
    {% endfor %}

    {# Success Toasts Dashboard #}
    {% for message in app.session.flashbag.get('success_admin') %}
        {{ include('dashboard/shared/_toast.html.twig', {
            toast_type: 'toast-success',
            message: message
        }) }}
    {% endfor %}
</div>
