<div
        id="loading-overlay"
        data-controller="loading"
        class="
        fixed inset-0 z-50
        flex items-center justify-center
        bg-white/80
        opacity-0 pointer-events-none
        transition-opacity duration-300 ease-out
    "
>
    <div
            id="loading-content"
            class="
        flex flex-col items-center justify-center
        w-full h-full gap-8
        scale-95 translate-y-2
        transition-all duration-300 ease-out
    "
    >

        {# Full-screen flex container #}
        <div class="flex flex-col items-center justify-center w-full h-full gap-8">
            {# Animated Circle + Logo #}
            <div class="relative flex items-center justify-center">
                {# Animated Circle #}
                <svg
                        class="w-[25vw] h-[25vw] min-w-[150px] min-h-[150px] max-w-[400px] max-h-[400px]"
                        viewBox="0 0 100 100"
                >
                    <circle
                            cx="50"
                            cy="50"
                            r="45"
                            fill="none"
                            stroke="#E5E7EB"
                            stroke-width="3"
                    ></circle>

                    <circle
                            cx="50"
                            cy="50"
                            r="45"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="6"
                            stroke-linecap="round"
                            class="text-primary"
                            stroke-dasharray="1 212"
                            stroke-dashoffset="0"
                    >
                        <animate
                                attributeName="stroke-dasharray"
                                values="1 212; 70 212; 1 212"
                                keyTimes="0; 0.5; 1"
                                dur="1.6s"
                                calcMode="spline"
                                keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"
                                repeatCount="indefinite"
                        ></animate>

                        <animate
                                attributeName="stroke-dashoffset"
                                values="0; -106; -212"
                                keyTimes="0; 0.5; 1"
                                dur="1.6s"
                                calcMode="spline"
                                keySplines="0.4 0 0.2 1; 0.4 0 0.2 1"
                                repeatCount="indefinite"
                        ></animate>
                    </circle>
                </svg>

                {# Logo centered over circle #}
                <img
                        src="{{ asset('resources/logos/openroaming-loading-logo.svg') }}"
                        alt="Loading"
                        id="loading-logo"
                        class="absolute w-[12vw] h-[12vw] min-w-[80px] min-h-[80px] max-w-[200px] max-h-[200px] scale-75 opacity-0 transition-all duration-[1000ms] ease-out"
                />
            </div>

            {# Loading text #}
            <span class="font-medium text-gray-700 text-2xl md:text-3xl lg:text-4xl xl:text-5xl flex items-center">
            {{ 'loading'|trans({}, '_blacklist') }}
            <span class="flex ml-2">
                <span class="animate-pulse [animation-delay:0s]">.</span>
                <span class="animate-pulse [animation-delay:0.3s]">.</span>
                <span class="animate-pulse [animation-delay:0.6s]">.</span>
            </span>
        </span>
        </div>
    </div>
</div>

<script>
    // Add smooth entry animation
    function showLoading() {
        const overlay = document.getElementById('loading-overlay');
        const content = document.getElementById('loading-content');
        const logo = document.getElementById('loading-logo');

        if (!overlay || !content || !logo) return;

        overlay.classList.remove('opacity-0', 'pointer-events-none');
        overlay.classList.add('opacity-100');

        content.classList.remove('scale-95', 'translate-y-2');
        content.classList.add('scale-100', 'translate-y-0');

        logo.classList.remove('scale-75', 'opacity-0');
        logo.classList.add('scale-100', 'opacity-100');
    }

    // Show overlay when links or forms are triggered
    document.addEventListener('click', (e) => {
        const link = e.target.closest('a[href]');
        if (!link) return;
        if (link.target === '_blank') return;
        if (link.hasAttribute('download')) return;

        showLoading();
    });

    document.addEventListener('submit', () => {
        showLoading();
    });
</script>
