{% extends '/landing/base.html.twig' %}

{% block title %}
    {{ data.PAGE_TITLE.value }}
{% endblock %}

{% block second_col %}

    {# Toasts #}
    {{ block('toast_messages') }}

    {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
        <img class="w-[120px] h-[58px] object-scale-down mt-[75px]"
             src="{{ data.CUSTOMER_LOGO.value }}"
             alt="{{ 'logoAlt'|trans({}, 'forgot_password_checker') }}"/>
    {% endif %}

    <div class="{{ data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value ? 'pt-[28px]' : 'pt-[161px]' }} leading-7">
        <p class="font-bold text-xl">
            {{ 'title'|trans({}, 'forgot_password_checker') }}
        </p>
        <p class="text-lg">
            {{ 'description'|trans({}, 'forgot_password_checker')|raw }}
        </p>
    </div>

    {# Form Column #}
    {{ form_start(forgotPasswordChecker) }}

    {# Current Password #}
    <div class="mt-6 flex flex-col gap-x-6 gap-y-8">
        <div class="flex flex-col lg:flex-row gap-x-6 gap-y-8">
            {# New Password #}
            <div class="relative w-full">
                {{ form_label(forgotPasswordChecker.password, 'form.currentPassword'|trans({}, 'forgot_password_checker'), {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(forgotPasswordChecker.password, {attr: {class: 'form-widget', 'data-fields-target': 'input', 'data-action': 'fields#input_changed'}}) }}
                {{ form_errors(forgotPasswordChecker.password) }}
            </div>

            <div class="hidden lg:flex w-full"></div>
        </div>

        {# New Password #}
        <div class="flex flex-col lg:flex-row gap-x-6 gap-y-8">
            <div class="relative w-full">
                {{ form_label(forgotPasswordChecker.newPassword, 'form.newPassword'|trans({}, 'forgot_password_checker'), {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(forgotPasswordChecker.newPassword, {attr: {class: 'form-widget', minlength: 7, 'data-fields-target': 'input', 'data-action': 'fields#input_changed'}}) }}
                {{ form_errors(forgotPasswordChecker.newPassword) }}
            </div>

            {# Confirm Password #}
            <div class="relative w-full">
                {{ form_label(forgotPasswordChecker.confirmPassword, 'form.confirmPassword'|trans({}, 'forgot_password_checker'), {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(forgotPasswordChecker.confirmPassword, {attr: {class: 'form-widget', minlength: 7, 'data-fields-target': 'input', 'data-action': 'fields#input_changed'}}) }}
                {{ form_errors(forgotPasswordChecker.confirmPassword) }}
            </div>
        </div>
    </div>

    {# Turnstile Checker #}
    {% if data.TURNSTILE_CHECKER.value == constant('App\\Enum\\OperationMode::ON').value %}
        <div class="ml-3 mt-5">
            {{ form_widget(forgotPasswordChecker.security) }}
        </div>
    {% endif %}

    {# Button Submit #}
    {{ form_row(forgotPasswordChecker._token) }}

    <div class="my-[32px] 2xl:pr-[18%] grid lg:grid-cols-1 grid-cols-2 xl:grid-cols-2 gap-4">
        <button type="submit" class="btn-primary">
            {{ 'form.submit'|trans({}, 'forgot_password_checker') }}
        </button>
    </div>

    {{ form_end(forgotPasswordChecker) }}

    {{ include ('landing/shared/returnActions/_logout.html.twig') }}
{% endblock %}
