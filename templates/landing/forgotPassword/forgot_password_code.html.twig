{% extends '/landing/base.html.twig' %}

{% block title %}
    {{ data.PAGE_TITLE.value|trans({}, 'forgot_password_code') }}
{% endblock %}

{% block second_col %}
    {# Form Column #}
    {# Toasts #}
    {{ block('toast_messages') }}

    {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
        <img
                class="w-[120px] h-[58px] object-scale-down mt-[75px]"
                src="{{ data.CUSTOMER_LOGO.value }}"
                alt="Customer Logo"
        />
    {% endif %}

    <div class="{{ data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value ? 'pt-[28px]' : 'pt-[161px]' }} leading-7">
        <p class="font-bold text-xl">{{ 'password_reset_request.title'|trans({}, 'forgot_password_code') }}</p>
        <p class="text-lg">
            {{ 'password_reset_request.instruction'|trans({}, 'forgot_password_code') }}
            <strong>{{ 'password_reset_request.verification_code'|trans({}, 'forgot_password_code') }}</strong>
            {{ 'password_reset_request.sent_via'|trans({}, 'forgot_password_code') }}
            <strong>{{ 'password_reset_request.sms'|trans({}, 'forgot_password_code') }}</strong>
        </p>
    </div>

    {{ form_start(forgotPasswordCode) }}

    <div class="mt-6 relative">
        <label for="forgotPasswordCode_verificationCode" class="form-label">{{ 'password_reset_request.code_label'|trans({}, 'forgot_password_code') }}</label>

        {{ form_widget(forgotPasswordCode.verificationCode, {
            attr: {
                class: 'form-widget',
                placeholder: 'password_reset_request.code_placeholder'|trans({}, 'forgot_password_code'),
                maxlength: 6,
                inputmode: 'numeric',
                pattern: '[0-9]*',
                oninput: "this.value = this.value.replace(/[^0-9]/g, '').slice(0, this.maxLength);",
            },
        }) }}
    </div>

    {{ form_row(forgotPasswordCode._token) }}

    <div class="my-[32px] 2xl:pr-[18%] grid lg:grid-cols-1 grid-cols-2 xl:grid-cols-2 gap-4">
        <button type="submit" class="btn-primary">
            {{ 'password_reset_request.confirm_button'|trans({}, 'forgot_password_code') }}
        </button>
    </div>

    <button class="w-[160px] btn-secondary" onClick="window.history.back();">
        {{ 'password_reset_request.go_back_button'|trans({}, 'forgot_password_code') }}
    </button>

    {{ form_end(forgotPasswordCode) }}

{% endblock %}
