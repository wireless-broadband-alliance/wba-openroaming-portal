{% extends '/landing/base.html.twig' %}

{% block title %}
    {{ data.PAGE_TITLE.value }}
{% endblock %}

{% block second_col %}

    {# Toasts #}
    {{ block('toast_messages') }}

    {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
        <img class="w-[120px] h-[58px] object-scale-down mt-[75px]" src="{{ data.CUSTOMER_LOGO.value }}" alt="Logo"/>
    {% endif %}

    <div class="{{ data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value ? 'pt-[28px]' : 'pt-[161px]' }} leading-7">
        <p class="font-bold text-xl">{{ 'title'|trans({}, 'forgot_password_sms') }}</p>
        <p class="text-lg">{{ 'description'|trans({}, 'forgot_password_sms')|raw }}</p>
    </div>

    {# Form Column #}
    {{ form_start(forgotPasswordSMSForm) }}

    <div class="flex flex-row items-end space-x-4 mt-8">
        {# Phone Number Input #}
        <div class="flex flex-col w-1/3">
            {{ form_label(forgotPasswordSMSForm.phoneNumber, 'form.phoneNumber'|trans({}, 'forgot_password_sms'), {
                label_attr: {
                    class: 'text-gray-700 font-medium mb-2',
                },
            }) }}
            {{ form_widget(forgotPasswordSMSForm.phoneNumber.children.country, {
                attr: {
                    class: 'block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary',
                    placeholder: 'form.countryPlaceholder'|trans({}, 'forgot_password_sms'),
                    autocomplete: 'tel',
                },
            }) }}
        </div>
        <div class="flex flex-col w-2/3">
            {{ form_widget(forgotPasswordSMSForm.phoneNumber.children.number, {
                attr: {
                    class: 'block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary',
                    placeholder: 'form.phoneNumberPlaceholder'|trans({}, 'forgot_password_sms'),
                    autocomplete: 'tel',
                },
            }) }}
        </div>
    </div>

    {# Turnstile Checker #}
    {% if data.TURNSTILE_CHECKER.value == constant('App\\Enum\\OperationMode::ON').value %}
        <div class="ml-3 mt-5">
            {{ form_widget(forgotPasswordSMSForm.security) }}
        </div>
    {% endif %}

    {# Button Submit #}
    {{ form_row(forgotPasswordSMSForm._token) }}

    <div class="my-[32px] 2xl:pr-[18%] grid lg:grid-cols-1 grid-cols-2 xl:grid-cols-2 gap-4">
        <button type="submit" class="btn-primary">
            {{ 'form.submit'|trans({}, 'forgot_password_sms') }}
        </button>
        {% if data.PLATFORM_MODE.value != constant('App\\Enum\\PlatformMode::DEMO').value %}
            <a href="{{ path('app_landing') }}" class="btn-secondary">
                {{ 'form.chooseAnother'|trans({}, 'forgot_password_sms') }}
            </a>
        {% endif %}
    </div>

    {% if data.AUTH_METHOD_LOGIN_TRADITIONAL_ENABLED.value == 'true' %}
        {# Divider #}
        <div class="my-[25px] divider"></div>

        <p class="text-xs">
            {{ 'form.didYouReceive'|trans({}, 'forgot_password_sms') }}
            <a href="{{ path('app_login') }}" class="font-semibold text-primary underline">{{ 'form.loginHere'|trans({}, 'forgot_password_sms') }}</a>
        </p>
    {% endif %}

    {% if data.AUTH_METHOD_REGISTER_ENABLED.value or data.AUTH_METHOD_SMS_REGISTER_ENABLED.value and data.AUTH_METHOD_TRADITIONAL_ENABLED.value == 'true' %}
        <p class="mt-2 text-xs">
            {{ 'form.noAccountRegister'|trans({}, 'forgot_password_sms') }}

            {% if data.AUTH_METHOD_REGISTER_ENABLED.value == 'true' %}
                <a href="{{ path('app_register') }}" class="font-semibold text-primary underline">
                    {{ 'form.withEmail'|trans({}, 'forgot_password_sms') }}</a>
            {% endif %}

            {% if data.AUTH_METHOD_REGISTER_ENABLED.value and data.AUTH_METHOD_SMS_REGISTER_ENABLED.value == 'true' %}
                {{ 'form.or'|trans({}, 'forgot_password_sms') }}
            {% endif %}

            {% if data.AUTH_METHOD_REGISTER_ENABLED.value == 'true' %}
                <a href="{{ path('app_register_sms') }}" class="font-semibold text-primary underline">
                    {{ 'form.withPhoneNumber'|trans({}, 'forgot_password_sms') }}</a>
            {% endif %}
        </p>
    {% endif %}

    {{ form_end(forgotPasswordSMSForm) }}

{% endblock %}
