<div class="relative flex justify-end" data-controller="dropdown">
    <label for="language-selector"
           class="block text-sm font-medium text-gray-900 mr-2 self-center">{{ 'language'|trans({}, 'landing') }}</label>

    <div class="relative w-44">
        {# Dropdown Button #}
        <button
                class="flex items-center justify-between w-full px-4 py-2 text-sm bg-white border border-gray-300 rounded-lg shadow-sm focus:outline-none"
                type="button"
                data-action="click->dropdown#toggle"
                data-dropdown-target="button">
            <div class="flex items-center space-x-2">
                {% if app.request.locale == 'en' %}
                    <twig:ux:icon class="w-4 h-4 rounded-full" name="wba:gb-flag" />
                    <span>English</span>
                {% else %}
                    <twig:ux:icon class="w-4 h-4 rounded-full" name="wba:portugal-flag" />
                    <span>Portuguese</span>
                {% endif %}
            </div>
            <twig:ux:icon class="w-4 h-4 text-gray-500" name="wba:arrow-down" />
        </button>

        {# Dropdown Menu #}
        <ul
                class="absolute hidden mt-2 divide-y divide-gray-100 rounded-lg bg-white shadow-lg text-sm w-full z-10"
                data-dropdown-target="menu">
            <li
                    class="flex items-center space-x-2 px-4 py-2 cursor-pointer hover:text-lightGreen {{ app.request.locale == 'en' ? 'bg-gray-100 font-semibold' : '' }}">
                <twig:ux:icon class="w-4 h-4 rounded-full" name="wba:gb-flag"/>
                <a href="{{ path('change_language', {locale: 'en'}) }}" class="block w-full">English</a>
            </li>
            <li
                    class="flex items-center space-x-2 px-4 py-2 cursor-pointer hover:text-lightGreen {{ app.request.locale == 'pt' ? 'bg-gray-100 font-semibold' : '' }}">
                <twig:ux:icon class="w-4 h-4 rounded-full" name="wba:portugal-flag"/>
                <a href="{{ path('change_language', {locale: 'pt'}) }}" class="block w-full">Portuguese</a>
            </li>
        </ul>
    </div>
</div>
