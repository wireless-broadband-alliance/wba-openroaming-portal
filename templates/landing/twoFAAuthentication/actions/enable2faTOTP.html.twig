{% extends 'landing/base.html.twig' %}

{% block title %}
    {{ data.title.value }}
{% endblock %}

{% block second_col %}

    {# Toasts #}
    {{ block('toast_messages') }}

    {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
        <img class="w-[120px] h-[58px] object-scale-down mt-[75px]" src="{{ data.customerLogoName.value }}"
             alt="{{ 'logoAlt'|trans({}, 'enable2FATOTP') }}"/>
    {% endif %}

    <div class="{{ data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value ? 'pt-[28px]' : 'pt-[161px]' }} leading-7">
        <p class="font-bold text-xl">{{ 'heading'|trans({}, 'enable2FATOTP') }}</p>
        <p class="text-lg">
            {{ 'instructions'|trans({}, 'enable2FATOTP') }}
        </p>

        {# Application Cards #}
        <div class="grid grid-cols-1 gap-6 mt-6">
            {# Google Authenticator #}
            <div class="flex items-center p-4 bg-gray-100 rounded-lg shadow-md hover:shadow-lg transition">
                <twig:ux:icon name="wba:google-authenticator"
                              class="w-10 h-10 md:w-12 md:h-12 inline-block mr-4 text-red-500"/>
                <div>
                    <p class="font-medium text-lg">{{ 'googleAuth.name'|trans({}, 'enable2FATOTP') }}</p>
                    <p>
                        {{ 'googleAuth.availableOn'|trans({}, 'enable2FATOTP') }}
                        <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2"
                           target="_blank" class="text-blue-500 underline"
                           rel="noopener noreferrer nofollow">{{ 'googleAuth.googlePlay'|trans({}, 'enable2FATOTP') }}</a> {{ 'and'|trans({}, 'enable2FATOTP') }}
                        <a href="https://apps.apple.com/app/google-authenticator/id388497605"
                           target="_blank" class="text-blue-500 underline"
                           rel="noopener noreferrer nofollow">{{ 'googleAuth.appStore'|trans({}, 'enable2FATOTP') }}</a>.
                    </p>
                </div>
            </div>

            {# Microsoft Authenticator #}
            <div class="flex items-center p-4 bg-gray-100 rounded-lg shadow-md hover:shadow-lg transition">
                <twig:ux:icon name="wba:microsoft-auth" class="w-10 h-10 md:w-12 md:h-12 inline-block mr-4"/>
                <div>
                    <p class="font-medium text-lg">{{ 'microsoftAuth.name'|trans({}, 'enable2FATOTP') }}</p>
                    <p>
                        {{ 'microsoftAuth.availableOn'|trans({}, 'enable2FATOTP') }}
                        <a href="https://play.google.com/store/apps/details?id=com.azure.authenticator"
                           target="_blank" class="text-blue-500 underline"
                           rel="noopener noreferrer nofollow">{{ 'microsoftAuth.googlePlay'|trans({}, 'enable2FATOTP') }}</a> {{ 'and'|trans({}, 'enable2FATOTP') }}
                        <a href="https://apps.apple.com/app/microsoft-authenticator/id983156458"
                           target="_blank" class="text-blue-500 underline"
                           rel="noopener noreferrer nofollow">{{ 'microsoftAuth.appStore'|trans({}, 'enable2FATOTP') }}</a>.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <p class="text-lg">{{ 'steps.heading'|trans({}, 'enable2FATOTP') }}</p>
        <ol class="pl-5 list-decimal text-lg mt-2">
            <li>{{ 'steps.install'|trans({}, 'enable2FATOTP') }}</li>
            <li>{{ 'steps.addAccount'|trans({}, 'enable2FATOTP') }}</li>
            <li>{{ 'steps.scanCode'|trans({}, 'enable2FATOTP') }}</li>
            <li>{{ 'steps.useCode'|trans({}, 'enable2FATOTP') }}</li>
        </ol>
    </div>

    {# QR Code Section #}
    <div class="flex justify-center my-5">
        <img src="data:image/png;base64,{{ qrCodeImage }}" alt="{{ 'qrCodeAlt'|trans({}, 'enable2FATOTP') }}"/>
    </div>

    <div class="{{ data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value ? 'pt-[28px]' : 'pt-[161px]' }} leading-7">
        <p class="text-lg">{{ 'manualCode'|trans({}, 'enable2FATOTP') }}</p>
        <div data-controller="clipboard">
            <div class="mt-5 rounded-md">
                <div id="codesBox"
                     data-clipboard-target="code"
                     class="p-4 bg-gray-100 text-base font-mono rounded-md overflow-x-auto text-left mt-4">
                    <div class="flex justify-end">
                        <button
                                data-action="clipboard#copyToClipboard">
                            <twig:ux:icon class="w-4" name="wba:copy"/>
                        </button>
                    </div>
                    <p class="text-sm">{{ secret }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Form Section #}
    {{ form_start(form) }}
    <div class="relative mt-10 mb-6">
        {{ form_widget(form.code, {
            attr: {
                class: 'form-widget',
                placeholder: 'form.placeholder'|trans({}, 'enable2FATOTP'),
            }}) }}
    </div>

    {# Action Button #}
    <div class="grid mt-4 grid-cols-1 sm:gap-4 lg:gap-6 sm:[grid-template-columns:repeat(auto-fit,minmax(150px,1fr))] md:my-2 my-3 space-y-4 sm:space-y-0">
        <button class="btn-primary"
                type="submit">{{ 'form.submit'|trans({}, 'enable2FATOTP') }}</button>
    </div>
    {{ form_end(form) }}

    {{ include('landing/shared/returnActions/_return_action.html.twig') }}
{% endblock %}
