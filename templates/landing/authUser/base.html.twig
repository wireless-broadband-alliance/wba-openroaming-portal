{% set bgUrl = data.WALLPAPER_IMAGE.value != '/resources/images/wallpaper.png'
    ? data.WALLPAPER_IMAGE.value
    : '/resources/images/background.png' %}

{% extends 'landing/base.html.twig' %}

{% block title %}
    {{ data.PAGE_TITLE.value }}
{% endblock %}

{% block body %}
    <div class="relative min-h-screen w-screen bg-center bg-cover flex flex-col justify-center items-center py-10 px-10"
         style="background-image: url('{{ bgUrl }}');">

        <div class="bg-white rounded-2xl shadow-xl w-[90%] max-w-6xl max-h-[80vh] h-auto flex flex-col p-6">
            <div class="flex flex-col md:flex-row justify-between items-center w-full px-6 py-2 gap-4">

                {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
                    <img class="w-[120px] h-[58px] object-scale-down"
                         src="{{ data.CUSTOMER_LOGO.value }}"
                         alt="Customer Logo"/>
                {% endif %}

                <div class="mt-0 md:mt-0">
                    {% block language %}
                        {{ include('shared/_select_language.html.twig', {
                            currentLocale: app.request.locale,
                            routeName: 'change_language',
                            warningMessage: false,
                        }) }}
                    {% endblock %}
                </div>
            </div>
            <div class="m-4">
                {% if isEEAUser() != constant('App\\Enum\\GeoLocation\\IsEEAHandler::NOT_IN_EEA').value %}
                    {{ include('landing/shared/_cookie_banner.html.twig') }}
                {% endif %}
            </div>
            <div class="flex-1 overflow-y-auto px-10 pb-10">
                    {% block content %}
                    {% endblock %}
            </div>
        </div>
    </div>
{% endblock %}

