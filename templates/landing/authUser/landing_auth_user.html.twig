{% set bgUrl = data.WALLPAPER_IMAGE.value != '/resources/images/wallpaper.png'
    ? data.WALLPAPER_IMAGE.value
    : '/resources/images/background.png' %}

{% extends 'landing/authUser/base.html.twig' %}

{% block title %}
    {{ data.PAGE_TITLE.value }}
{% endblock %}

{% block content %}

    {{ block('toast_messages') }}

    <div class="mt-6 leading-7">
        <p class="font-bold text-base sm:text-lg md:text-xl lg:text-2xl">
            {{ 'downloadInstallProfiles'|trans({}, 'landing') }}
        </p>
        <p class="mt-3 text-sm sm:text-base md:text-lg lg:text-xl">
            {{ 'profilesExplanation'|trans({}, 'landing') }}
        </p>
    </div>
    <form method="post" novalidate>
        {{ include('landing/shared/_os_selection.html.twig') }}
    </form>

    <div class="my-[25px] divider"></div>
    <div {{ stimulus_controller('widget') }}>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center w-full gap-4">
            <div>
                <p class="text-[#212529] text-opacity-40 text-sm">
                    {{ 'authenticatedAs'|trans({}, 'landing') }}
                    {% for auth in user.userExternalAuths %}
                        {% if auth.provider == constant('App\\Enum\\UserProvider::SAML').value %}
                            {{ auth.providerId }}
                        {% else %}
                            {{ app.user.uuid }}
                        {% endif %}
                    {% endfor %}
                </p>

                {% if app.user.isVerified %}
                    <div class="flex flex-row justify-end md:justify-start items-center gap-2 mt-2">
                        <p class="text-sm text-[#707070]">{{ 'title'|trans({}, '_account_widget') }}</p>
                        <button id="widgetUserButton" type="button" {{ stimulus_action('widget', 'open') }}
                                class="duration-300 cursor-pointer rounded-full text-[#707070] focus:animate-spin-slow focus:bg-[#7DB928] focus:text-white hover:shadow-lg p-2.5 relative z-0">
                            <twig:ux:icon name="wba:cog" class="w-6" fill="none"/>
                        </button>
                    </div>

                    <div {{ stimulus_target('widget', 'modal') }}
                            class="hidden fixed top-0 left-0 w-full h-full bg-[#090B2F] bg-opacity-70 z-40">
                        <div class="flex flex-row justify-center items-center h-full w-full">
                            {{ include('landing/shared/_account_widget.html.twig') }}
                        </div>
                    </div>
                {% endif %}
            </div>
            <div class="ml-auto">
                <a href="{{ path('app_logout') }}" class="w-[160px] btn-logout">
                    {{ 'logout'|trans({}, 'landing') }}
                </a>
            </div>
        </div>
    </div>
{% endblock %}
