{% extends '/landing/base.html.twig' %}

{% block title %}
    {{ data.title.value }}
{% endblock %}

{% block second_col %}
    {# Form Column #}

    {# Toasts #}
    {{ block('toast_messages') }}

    {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
        <img class="w-[120px] h-[58px] object-scale-down mt-[75px]"
             src="{{ data.customerLogoName.value }}"
             alt="{{ 'logoAlt'|trans({}, 'register_landing') }}"/>
    {% endif %}

    <div class="{{ data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value ? 'pt-[28px]' : 'pt-[161px]' }} leading-7">
        <p class="font-bold text-xl">{{ 'heading'|trans({}, 'register_landing') }}</p>
        <p class="text-lg">{{ 'description.1'|trans({}, 'register_landing') }}</p>
        <p class="text-lg">{{ 'description.2'|trans({}, 'register_landing') }}</p>
    </div>

    {{ form_start(registrationSMSForm) }}

    <div class="flex flex-row items-end space-x-4 mt-8">
        {# Phone Number Input #}
        <div class="flex flex-col w-1/3">
            {{ form_label(registrationSMSForm.phoneNumber, 'form.phone_number'|trans({}, 'register_landing'), {label_attr: {class: 'text-gray-700 font-medium mb-2'}}) }}
            {{ form_widget(registrationSMSForm.phoneNumber.children.country, {
                attr: {
                    class: 'block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary',
                    placeholder: 'form.phone_placeholder'|trans({}, 'register_landing'),
                    autocomplete: 'tel',
                },
            }) }}
        </div>
        <div class="flex flex-col w-2/3">
            {{ form_widget(registrationSMSForm.phoneNumber.children.number, {
                attr: {
                    class: 'block w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary',
                    placeholder: 'form.phone_placeholder'|trans({}, 'register_landing'),
                    autocomplete: 'tel',
                },
            }) }}
        </div>
    </div>

    {# Turnstile Checker #}
    {% if data.TURNSTILE_CHECKER.value == constant('App\\Enum\\OperationMode::ON').value %}
        <div class="ml-3 mt-5">
            {{ form_widget(registrationSMSForm.security) }}
        </div>
    {% endif %}

    {# Button Submit #}
    {{ form_row(registrationSMSForm._token) }}

    <div class="my-[32px] 2xl:pr-[18%] grid lg:grid-cols-1 grid-cols-2 xl:grid-cols-2 gap-4">
        <button type="submit" class="btn-primary">
            {{ 'form.submit'|trans({}, 'register_landing') }}
        </button>
        {% if data.PLATFORM_MODE != constant('App\\Enum\\PlatformMode::DEMO').value %}
            <a href="{{ path('app_landing') }}" class="btn-secondary">
                {{ 'form.choose_another'|trans({}, 'register_landing') }}
            </a>
        {% endif %}
    </div>

    {% if data.AUTH_METHOD_LOGIN_TRADITIONAL_ENABLED.value == 'true' %}
        {# Divider #}
        <div class="my-[25px] divider"></div>
        <p class="text-sm">
            {{ 'form.already_have_account'|trans({}, 'register_landing') }}
            <a href="{{ path('app_login') }}" class="font-semibold text-primary underline">
                {{ 'form.login'|trans({}, 'register_landing') }}
            </a> {{ 'form.here'|trans({}, 'register_landing') }}
        </p>
    {% endif %}

    {{ form_end(registrationSMSForm) }}

{% endblock %}
