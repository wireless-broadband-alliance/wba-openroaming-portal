{% extends '/landing/base.html.twig' %}

{% block title %}
    {{ data.title.value }}
{% endblock %}

{% block second_col %}

    {# Toasts #}
    {{ block('toast_messages') }}

    {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
        <img class="w-[120px] h-[58px] object-scale-down mt-[75px]" src="{{ data.customerLogoName.value }}" alt="Logo"/>
    {% endif %}

    <div class="{{ data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value ? 'pt-[28px]' : 'pt-[161px]' }} leading-7">
        <p class="font-bold text-xl">{{ 'title'|trans({}, 'forgot_password_email') }}</p>
        <p class="text-lg">{{ 'description'|trans({}, 'forgot_password_email') }}</p>
    </div>

    {# Form Column #}
    {{ form_start(forgotPasswordEmailForm) }}

    {# Email #}
    <div class="relative mt-[32px]">
        {{ form_label(forgotPasswordEmailForm.email, 'form.placeholder'|trans({}, 'forgot_password_email'), {
            label_attr: {
                class: 'form-label'
            }
        }) }}
        {{ form_widget(forgotPasswordEmailForm.email, {
            attr: {
                class: 'form-widget',
                placeholder: 'form.placeholder'|trans({}, 'forgot_password_email')
            },
        }) }}
    </div>

    {# Turnstile Checker #}
    {% if data.TURNSTILE_CHECKER.value == constant('App\\Enum\\OperationMode::ON').value %}
        <div class="ml-3 mt-5">
            {{ form_widget(forgotPasswordEmailForm.security) }}
        </div>
    {% endif %}

    {# Button Submit #}
    {{ form_row(forgotPasswordEmailForm._token) }}

    <div class="my-[32px] 2xl:pr-[18%] grid lg:grid-cols-1 grid-cols-2 xl:grid-cols-2 gap-4">
        <button type="submit" class="btn-primary">
            {{ 'form.submit'|trans({}, 'forgot_password_email') }}
        </button>
        {% if data.PLATFORM_MODE != constant('App\\Enum\\PlatformMode::DEMO').value %}
            <a href="{{ path('app_landing') }}" class="btn-secondary">
                {{ 'form.chooseAnother'|trans({}, 'forgot_password_email') }}
            </a>
        {% endif %}
    </div>

    {% if data.LOGIN_TRADITIONAL_ENABLED.value == true %}
        {# Divider #}
        <div class="my-[25px] divider"></div>

        <p class="text-xs">
            {{ 'form.didYouReceive'|trans({}, 'forgot_password_email') }}
            <a href="{{ path('app_login') }}"
               class="font-semibold text-primary underline">{{ 'form.loginHere'|trans({}, 'forgot_password_email') }}</a>
        </p>
    {% endif %}

    {% if data.EMAIL_REGISTER_ENABLED.value or data.AUTH_METHOD_SMS_REGISTER_ENABLED.value %}
        <p class="mt-2 text-xs">{{ 'form.noAccountRegister'|trans({}, 'forgot_password_email') }}

            {% if data.EMAIL_REGISTER_ENABLED.value %}
                <a href="{{ path('app_register') }}" class="font-semibold text-primary underline">
                    {{ 'form.withEmail'|trans({}, 'forgot_password_email') }}</a>
            {% endif %}

            {% if data.EMAIL_REGISTER_ENABLED.value and data.AUTH_METHOD_SMS_REGISTER_ENABLED.value %}
                {{ 'form.or'|trans({}, 'forgot_password_email') }}
            {% endif %}

            {% if data.AUTH_METHOD_SMS_REGISTER_ENABLED.value %}
                <a href="{{ path('app_register_sms') }}" class="font-semibold text-primary underline">
                    {{ 'form.withPhoneNumber'|trans({}, 'forgot_password_email') }}</a>
            {% endif %}
        </p>
    {% endif %}

    {{ form_end(forgotPasswordEmailForm) }}

{% endblock %}
