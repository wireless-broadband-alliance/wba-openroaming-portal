{% extends 'landing/base.html.twig' %}

{% block title %}
    {{ data.PAGE_TITLE.value }}
{% endblock %}

{% block second_col %}

    {# Toasts #}
    {{ block('toast_messages') }}

    {% if data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value %}
        <img class="w-[120px] h-[58px] object-scale-down mt-[75px]" src="{{ data.CUSTOMER_LOGO.value }}" alt="{{ 'logoAlt'|trans({}, 'validate2FA') }}"/>
    {% endif %}

    <div class="{{ data.CUSTOMER_LOGO_ENABLED.value == constant('App\\Enum\\OperationMode::ON').value ? 'pt-[28px]' : 'pt-[161px]' }} leading-7">
        <p class="font-bold text-xl">{{ 'welcome_back'|trans({}, 'login_landing') }}</p>
        <p class="text-lg">{{ 'description'|trans({}, 'login_landing') }}</p>
    </div>

    {# Form Column #}
    {{ form_start(form) }}
    <div class="relative mt-10 mb-6">
        {{ form_widget(form.email, {
            attr: {
                class: 'form-widget',
                placeholder: 'placeholder'|trans({}, 'validate2FA'),
            }}) }}
    </div>

    {# Action Buttons #}
    <div class="grid mt-4 grid-cols-1 sm:gap-4 lg:gap-6 sm:[grid-template-columns:repeat(auto-fit,minmax(150px,1fr))] md:my-2 my-3 space-y-4 sm:space-y-0">
        <button class="btn-primary"
                type="submit">{{ 'submit'|trans({}, 'validate2FA') }}</button>
    </div>
    {{ form_end(form) }}


{% endblock %}
