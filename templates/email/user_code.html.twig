<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ emailTitle }} - {{ 'codeVerification'|trans({}, 'user_code') }}</title>
</head>
<body style="background-color: #080D4A; font-family: ui-sans-serif, system-ui, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'; color: #4A5568; margin: 0; padding: 0;">
<div style="width: 100%; max-width: 600px; margin: 0 auto; padding: 3rem 1rem;">
    <div style="max-width: 448px; margin: 0 auto; background-color: #fff; border-radius: 16px; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1); overflow: hidden;">
        <div style="background-color: #7BBA29; color: #fff; padding: 1.5rem; text-align: center;">
            <h1 style="font-size: 1.5rem; font-weight: 700;">
                {% if is2FATemplate %}
                    {{ 'twoFactorAuthentication'|trans({}, 'user_code') }}
                {% else %}
                    {{ 'verifyAccount'|trans({}, 'user_code') }}
                {% endif %}
            </h1>
        </div>
        <div style="padding: 1.5rem;">
            {% if is2FATemplate %}
                <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                    {{ 'twoFactorAuthenticationCode'|trans({}, 'user_code') }}
                </p>
                <p style="text-align: center; font-size: 1.5rem; font-weight: 700; color: #0045AD; margin: 1.5rem 0;">
                    {{ twoFaCode }}
                </p>
                <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                    {{ 'validForSeconds'|trans({'%seconds%': secondsLeft}, 'user_code')|raw }}
                </p>
                <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                    {{ 'KeepConfidential'|trans({}, 'user_code') }}
                </p>
            {% else %}
                <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                    {{ 'authCode'|trans({}, 'user_code') }}
                </p>
                <p style="text-align: center; font-size: 1.5rem; font-weight: 700; color: #0045AD; margin: 1.5rem 0;">
                    {{ twoFaCode }}
                </p>
                <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                    {{ 'KeepConfidential'|trans({}, 'user_code') }}
                </p>
            {% endif %}
        </div>
        <div style="background-color: #f4f4f4; text-align: center; padding: 1.5rem;">
            <p style="font-size: 0.875rem; color: #718096;">
                {{ 'thankYou'|trans({}, 'user_code') }}<br>
                <strong>{{ 'team'|trans({'%supportTeam%': emailTitle}, 'user_code') }}</strong>
            </p>
        </div>
    </div>
</div>
</body>
</html>
