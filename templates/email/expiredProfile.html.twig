<!doctype html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>{{ 'subject_is_expired'|trans({}, 'expirationProfiles') }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet"/>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Poppins', sans-serif;
            background-color: #F4F4F4;
        }

        .container {
            width: 100%;
            max-width: 1100px;
            background: #fff;
            margin: 0 auto;
        }

        /* HEADER */
        .header {
            background-color: #0B1A58;
            width: 100%;
            min-height: 180px;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 3rem 1rem;
            box-sizing: border-box;
            margin-bottom: 2rem;
        }

        .header img {
            max-width: 100%;
            height: auto;
        }

        /* CONTENT */
        .content {
            width: 100%;
            background-color: #FFFFFF;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 3rem 2rem;
            margin-bottom: 2rem;
            box-sizing: border-box;
        }

        .content h1 {
            color: #0B1A58;
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 2.5rem;
        }

        .content p {
            font-size: 1.25rem;
            margin-bottom: 2rem;
            line-height: 1.5;
            color: #0B1A58;
        }

        .content p span {
            font-weight: 600;
        }

        .content p span.strong {
            font-weight: 700;
        }

        .btn-download {
            display: inline-block;
            width: 90%;
            max-width: 800px;
            padding: 1.25rem;
            background-color: #7BBA29;
            color: #0B1A58;
            font-size: 1.25rem;
            font-weight: 700;
            text-align: center;
            text-decoration: none;
            border-radius: 10px;
            transition: background-color 0.3s ease;
            margin-top: 1.25rem;
        }

        /* FOOTER */
        .footer {
            background-color: #E6E6E6;
            width: 100%;
            min-height: 160px;
            padding: 1.5rem 1rem;
            text-align: center;
            box-sizing: border-box;
        }

        .footer p {
            margin: 0.75rem 0;
            font-size: 1rem;
            color: #1A202C;
        }

        .footer a,
        .footer strong {
            color: #0B1A58;
            font-weight: 600;
            text-decoration: none;
        }

        /* Hover states */
        .footer a:hover,
        .footer a:focus {
            text-decoration: underline;
        }

        .btn-download:hover,
        .btn-download:focus {
            background-color: #669922;
            outline: none;
        }

        /* Responsive adjustments */
        @media only screen and (max-width: 768px) {
            .content h1 {
                font-size: 2rem;
            }

            .content p {
                font-size: 1.1rem;
            }

            .btn-download {
                font-size: 1.25rem;
                padding: 1.5rem;
            }

            .header img {
                width: 100%;
                max-width: 300px;
            }

            .footer p {
                font-size: 0.95rem;
            }
        }

        @media only screen and (max-width: 480px) {
            .content h1 {
                font-size: 1.5rem;
            }

            .content p {
                font-size: 1rem;
            }

            .btn-download {
                font-size: 1rem;
                padding: 1rem;
            }

            .header {
                padding: 2rem 1rem;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="container">
        <header class="header" role="banner">
            <img src="cid:logo_cid" alt="Customer Logo"/>
        </header>
    </div>

    <main class="content" role="main">
        <h1>{{ 'header'|trans({}, 'expirationProfiles') }}</h1>
        <p>
            {{ 'expired_message'|trans({}, 'expirationProfiles')|raw }}
        </p>
        <a href="{{ absolute_url(path('app_landing')) ~ '?uuid=' ~ uuid|url_encode|url_encode }}" class="btn-download">
            {{ 'new_profile'|trans({}, 'expirationProfiles') }}
        </a>
    </main>

    <footer class="footer" role="contentinfo">
        <p>
            {{ 'footer.support_team'|trans({}, 'expirationProfiles') }}
            <a href="mailto:{{ contactEmail }}">{{ contactEmail }}</a>
        </p>
        <p>
            <strong>{{ 'footer.thank_you'|trans({}, 'expirationProfiles') }}</strong><br/>
            {{ 'footer.team'|trans({'%emailTitle%': emailTitle}, 'expirationProfiles') }}
        </p>
    </footer>
</div>
</body>
</html>
