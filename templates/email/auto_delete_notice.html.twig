<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auto Delete Notice - Warning</title>
</head>
<body style="background-color: #080D4A; font-family: ui-sans-serif, system-ui, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'; color: #4A5568; margin: 0; padding: 0;">
<div style="width: 100%; max-width: 600px; margin: 0 auto; padding: 3rem 1rem;">
    <div style="max-width: 600px; margin: 0 auto; background-color: #fff; border-radius: 16px; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1); overflow: hidden;">
        <!-- Header Content -->
        <div style="background-color: #FF6B6B; color: #fff; padding: 1.5rem; text-align: center;">
            <h1 style="font-size: 1.5rem; font-weight: 700;">
                {{ 'account_deletion_title'|trans({}, 'auto_delete_notice') }}
            </h1>
        </div>

        <!-- Main Content -->
        <div style="padding: 1.5rem;">
            <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                {{ 'deletion_warning'|trans({}, 'auto_delete_notice') }}
            </p>
            <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                {{ 'deletion_confirmation'|trans({}, 'auto_delete_notice') }}
            </p>
            <p style="text-align: center; font-size: 1.5rem; font-weight: 700; color: #0045AD; margin: 1.5rem 0;">
                {{ deletionCode }}
            </p>
            <div style="background-color: #FFFAE6; padding: 1rem; border-left: 4px solid #FFD700; margin-top: 1rem; border-radius: 4px;">
                <p style="color: #856404; font-size: 1rem; margin: 0;">
                    {{ 'no_action_message'|trans({}, 'auto_delete_notice') }}
                </p>
            </div>
        </div>

        <!-- Footer Section -->
        <div style="background-color: #f4f4f4; text-align: center; padding: 1.5rem;">
            <p style="font-size: 0.875rem; color: #718096;">
                {{ 'footer.support_team'|trans({}, 'admin_reset') }}
                <a href="mailto:{{ contactEmail }}"
                   style="color: #0045AD; text-decoration: underline;">{{ contactEmail }}</a>
            </p>
            <p style="font-size: 0.875rem; color: #718096;">
                {{ 'footer.thank_you'|trans({}, 'admin_reset') }}<br>
                <strong>{{ emailTitle }}</strong>
            </p>
        </div>
    </div>
</div>
</body>
</html>
