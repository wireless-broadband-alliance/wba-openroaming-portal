<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OpenRoaming Registration</title>
</head>
<body style="margin:0; padding:0; background-color:#F4F4F4; font-family: Arial, sans-serif;">
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" bgcolor="#F4F4F4">
    <tr>
        <td align="center">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="background:#ffffff;">
                <tr>
                    <td align="center" bgcolor="#0B1A58" style="padding:30px;">
                        <img src="cid:logo_cid" alt="Customer Logo" style="max-width:200px; height:auto;" />
                    </td>
                </tr>

                <tr>
                    <td align="left" style="padding:40px; text-align:left; color:#0B1A58;">
                        <h1 style="font-size:24px; font-weight:bold; margin:0 0 20px 0; color:#0B1A58;">
                            {{ 'subject_2fa_disabled'|trans({}, 'admin_disabled2fa') }}
                        </h1>
                        <p style="font-size:16px; line-height:1.5; margin:0 0 20px 0;">
                            {{ 'greeting'|trans({'%uuid%': uuid}, 'admin_disabled2fa') }}
                        </p>
                        <p style="font-size:16px; line-height:1.5; margin:0 0 20px 0;">
                            {{ 'info_2fa_disabled'|trans({}, 'admin_disabled2fa')|raw }}<br/>
                            {{ 'warning_contact_support'|trans({}, 'admin_disabled2fa')|raw }}<br/>
                            {{ 'recommend_re_enable_2fa'|trans({}, 'admin_disabled2fa')|raw }}
                        </p>
                    </td>
                </tr>

                <tr>
                    <td bgcolor="#E6E6E6" align="center" style="padding:20px; font-size:14px; color:#1A202C;">
                        <p style="margin:0 0 10px 0;">
                            {{ 'footer.support_team'|trans({}, 'user_registration') }}
                            <a href="mailto:{{ contactEmail }}" style="color:#0B1A58; font-weight:bold; text-decoration:none;">
                                {{ contactEmail }}
                            </a>
                        </p>
                        <p style="margin:0;">
                            <strong style="color:#0B1A58;">{{ 'footer.thank_you'|trans({}, 'user_registration') }}</strong><br/>
                            {{ 'footer.team'|trans({'%supportTeam%': supportTeam}, 'user_registration') }}
                        </p>
                    </td>
                </tr>

            </table>
        </td>
    </tr>
</table>
</body>
</html>
