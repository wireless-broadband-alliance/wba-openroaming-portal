<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ 'header_reset_password'|trans({}, 'user_password_reset') }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Poppins', sans-serif;
            background-color: #F4F4F4;
        }

        .container {
            width: 100%;
            max-width: 1100px;
            background: #fff;
            margin: 0 auto;
        }

        .header {
            background-color: #0B1A58;
            width: 100%;
            min-height: 180px;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 3rem 1rem;
            box-sizing: border-box;
            margin-bottom: 2rem;
        }

        .header img {
            max-width: 100%;
            height: auto;
        }

        .content {
            width: 100%;
            background-color: #FFFFFF;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 3rem 2rem;
            margin-bottom: 2rem;
            box-sizing: border-box;
        }

        .content h1 {
            color: #0B1A58;
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 2rem;
        }

        .content p {
            font-size: 1.25rem;
            margin-bottom: 1.5rem;
            line-height: 1.6;
            color: #0B1A58;
        }

        .content .password-box {
            font-size: 2rem;
            font-weight: 700;
            color: #0045AD;
            margin: 2rem 0;
        }

        .footer {
            background-color: #E6E6E6;
            width: 100%;
            min-height: 160px;
            padding: 1.5rem 1rem;
            text-align: center;
            box-sizing: border-box;
        }

        .footer p {
            margin: 0.75rem 0;
            font-size: 1rem;
            color: #1A202C;
        }

        .footer a,
        .footer strong {
            color: #0B1A58;
            font-weight: 600;
            text-decoration: none;
        }

        .footer a:hover,
        .footer a:focus {
            text-decoration: underline;
        }

        @media only screen and (max-width: 768px) {
            .content h1 {
                font-size: 2rem;
            }

            .content p {
                font-size: 1.1rem;
            }

            .content .password-box {
                font-size: 1.75rem;
            }

            .header img {
                width: 100%;
                max-width: 300px;
            }

            .footer p {
                font-size: 0.95rem;
            }
        }

        @media only screen and (max-width: 480px) {
            .content h1 {
                font-size: 1.5rem;
            }

            .content p,
            .footer p {
                font-size: 1rem;
            }

            .content .password-box {
                font-size: 1.5rem;
            }

            .header {
                padding: 2rem 1rem;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <!-- Header with logo -->
    <header class="header" role="banner">
        <img src="cid:logo_cid" alt="Customer Logo" />
    </header>

    <!-- Main content -->
    <div class="content">
        <h1>{{ 'header_reset_password'|trans({}, 'user_password_reset') }}</h1>
        <p>{{ 'password_reset_intro'|trans({}, 'user_password_reset') }}</p>
        <div class="password-box">{{ password }}</div>
        <p>{{ 'password_reset_warning'|trans({}, 'user_password_reset')|raw }}</p>
    </div>

    <!-- Footer -->
    <footer class="footer" role="contentinfo">
        <p>
            {{ 'footer.support_team'|trans({}, 'user_password_reset') }}
            <a href="mailto:{{ contactEmail }}">{{ contactEmail }}</a>
        </p>
        <p>
            {{ 'footer.thank_you'|trans({}, 'user_password_reset') }}<br />
            <strong>{{ 'footer.team'|trans({'%supportTeam%': supportTeam}, 'user_password_reset') }}</strong>
        </p>
    </footer>
</div>
</body>
</html>
