<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ 'header_reset_password'|trans({}, 'user_password_reset') }}</title>
</head>
<body style="margin:0; padding:0; font-family: Arial, Helvetica, sans-serif; background-color:#F4F4F4; color:#0B1A58;">

<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#F4F4F4">
    <tr>
        <td align="center">

            <!-- Container -->
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:1100px; background-color:#FFFFFF; margin:0 auto;">

                <!-- Header -->
                <tr>
                    <td bgcolor="#0B1A58" align="center" style="padding:40px 20px;">
                        <img src="cid:logo_cid" alt="Customer Logo" style="max-width:300px; height:auto; border:0; display:block;" />
                    </td>
                </tr>

                <!-- Content -->
                <tr>
                    <td align="center" style="padding:40px 20px; font-size:16px; line-height:1.5; color:#0B1A58; font-family: Arial, Helvetica, sans-serif;">

                        <h1 style="color:#0B1A58; font-size:28px; font-weight:bold; margin:0 0 30px 0;">
                            {{ 'header_reset_password'|trans({}, 'user_password_reset') }}
                        </h1>

                        <p style="font-size:18px; line-height:1.5; margin:0 0 16px 0;">
                            {{ 'password_reset_intro'|trans({}, 'user_password_reset') }}
                        </p>

                        <div style="font-size:28px; font-weight:bold; color:#0045AD; margin:20px 0;">
                            {{ password }}
                        </div>

                        <p style="font-size:18px; line-height:1.5; margin:0 0 16px 0;">
                            {{ 'password_reset_warning'|trans({}, 'user_password_reset')|raw }}
                        </p>

                    </td>
                </tr>

                <!-- Footer -->
                <tr>
                    <td bgcolor="#E6E6E6" align="center" style="padding:20px; font-size:14px; color:#1A202C; font-family: Arial, Helvetica, sans-serif;">
                        <p style="margin:12px 0;">
                            {{ 'footer.support_team'|trans({}, 'user_password_reset') }}
                            <a href="mailto:{{ contactEmail }}" style="color:#0B1A58; font-weight:bold; text-decoration:none;">{{ contactEmail }}</a>
                        </p>
                        <p style="margin:12px 0;">
                            {{ 'footer.thank_you'|trans({}, 'user_password_reset') }}<br />
                            <strong style="color:#0B1A58;">
                                {{ 'footer.team'|trans({'%supportTeam%': supportTeam}, 'user_password_reset') }}
                            </strong>
                        </p>
                    </td>
                </tr>

            </table>
            <!-- End Container -->

        </td>
    </tr>
</table>

</body>
</html>
