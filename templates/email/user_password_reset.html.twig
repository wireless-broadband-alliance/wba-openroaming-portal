<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Open the door to OpenRoaming!</title>
</head>
<body style="background-color: #080D4A; font-family: ui-sans-serif, system-ui, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'; color: #4A5568; margin: 0; padding: 0;">
<div style="width: 100%; max-width: 600px; margin: 0 auto; padding: 3rem 1rem;">
    <div style="max-width: 600px; margin: 0 auto; background-color: #fff; border-radius: 16px; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1); overflow: hidden;">

        <!-- Title Section -->
        <div style="background-color: #7BBA29; color: #fff; text-align: center; padding: 1.5rem;">
            <h1 style="font-size: 1.5rem; font-weight: 700;">
                {{ 'header_reset_password'|trans({}, 'user_password_reset') }}
            </h1>
        </div>

        <!-- Main Content -->
        <div style="padding: 1.5rem;">
            <!-- Password Reset Instructions -->
            <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                {{ 'password_reset_intro'|trans({}, 'user_password_reset') }}
            </p>
            <p style="text-align: center; font-size: 1.5rem; font-weight: 700; color: #0045AD; margin: 1.5rem 0;">
                {{ password }}
            </p>
            <p style="font-size: 1.125rem;">
                {{ 'password_reset_warning'|trans({}, 'user_password_reset') }}
            </p>
        </div>

        <!-- Footer Section -->
        <div style="background-color: #f4f4f4; text-align: center; padding: 1.5rem;">
            <p style="font-size: 0.875rem; color: #718096;">
                {{ 'footer.support_team'|trans({}, 'user_password_reset') }}
                <a href="mailto:{{ contactEmail }}" style="color: #0045AD; text-decoration: underline;">
                    {{ contactEmail }}
                </a>
            </p>
            <p style="font-size: 0.875rem; color: #718096;">
                {{ 'footer.thank_you'|trans({}, 'user_password_reset') }}<br>
                <strong>{{ 'footer.team'|trans({'%supportTeam%': supportTeam}, 'user_password_reset') }}</strong>
            </p>
        </div>

    </div>
</div>
</body>
</html>
