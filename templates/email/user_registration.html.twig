<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Open the door to OpenRoaming!</title>
</head>
<body style="background-color: #080D4A; font-family: ui-sans-serif, system-ui, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'; color: #4A5568; margin: 0; padding: 0;">
<div style="width: 100%; max-width: 600px; margin: 0 auto; padding: 3rem 1rem;">
    <div style="max-width: 600px; margin: 0 auto; background-color: #fff; border-radius: 16px; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1); overflow: hidden;">

        <!-- Title Section -->
        <div style="background-color: #7BBA29; color: #fff; text-align: center; padding: 1.5rem;">
            <h1 style="font-size: 1.5rem; font-weight: 700;">
                {{ 'header_welcome'|trans({}, 'user_registration') }}
            </h1>
        </div>

        <!-- Main Content -->
        <div style="padding: 1.5rem;">
            <!-- New User Instructions -->
            <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                {{ 'intro_new_user'|trans({}, 'user_registration') }}
            </p>
            <ol style="margin-top: 1rem; font-size: 1.125rem; list-style-type: decimal; list-style-position: inside; padding-left: 0; margin-bottom: 0;">
                <li style="margin-bottom: 0.75rem;">
                    {{ 'new_user_steps.confirm_account'|trans({'%confirmLink%': absolute_url('/login/link') ~ '?' ~ 'uuid=' ~ uuid|url_encode ~ '&verificationCode=' ~ verificationCode}, 'user_registration')|raw }}
                </li>
                <li style="margin-bottom: 0.75rem;">
                    {{ 'new_user_steps.download_profile'|trans({}, 'user_registration')|raw }}
                </li>
                <li style="margin-bottom: 0.75rem;">
                    {{ 'new_user_steps.password'|trans({'%password%': password}, 'user_registration')|raw }}
                </li>
                <li style="margin-bottom: 0.75rem;">
                    {{ 'new_user_steps.enter_code'|trans({'%verificationCode%': verificationCode}, 'user_registration')|raw }}
                </li>
            </ol>
        </div>

        <!-- Footer Section -->
        <div style="background-color: #f4f4f4; text-align: center; padding: 1.5rem;">
            <p style="font-size: 0.875rem; color: #718096;">
                {{ 'footer.support_team'|trans({}, 'user_registration') }}
                <a href="mailto:{{ contactEmail }}" style="color: #0045AD; text-decoration: underline;">
                    {{ contactEmail }}
                </a>
            </p>
            <p style="font-size: 0.875rem; color: #718096;">
                {{ 'footer.thank_you'|trans({}, 'user_registration') }}<br>
                <strong>{{ 'footer.team'|trans({'%supportTeam%': supportTeam}, 'user_registration') }}</strong>
            </p>
        </div>

    </div>
</div>
</body>
</html>
