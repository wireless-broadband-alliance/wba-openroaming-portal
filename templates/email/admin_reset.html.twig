<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>{{ 'header_settings_reset'|trans({}, 'admin_reset') }}</title>
</head>
<body style="margin:0; padding:0; background-color:#F4F4F4; font-family:Arial, sans-serif; color:#0B1A58;">

<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" bgcolor="#F4F4F4">
    <tr>
        <td align="center">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" bgcolor="#ffffff" style="margin:0 auto;">

                <tr>
                    <td bgcolor="#0B1A58" align="center" style="padding:40px;">
                        <img src="cid:logo_cid" alt="Customer Logo" style="max-width:300px; height:auto; display:block;" />
                    </td>
                </tr>

                <tr>
                    <td align="left" style="padding:40px; color:#0B1A58; font-size:16px; line-height:1.5;">
                        <h1 style="font-size:24px; font-weight:bold; margin:0 0 20px 0;">{{ 'header_settings_reset'|trans({}, 'admin_reset') }}</h1>
                        <p style="margin:0 0 16px 0;">{{ 'message_settings_reset'|trans({'%settingCategory%': settingCategory}, 'admin_reset')|raw }}</p>
                        <p style="margin:0 0 16px 0;">
                            {{ 'confirmation_code'|trans({}, 'admin_reset') }}
                            <span style="font-weight:bold; color:#0045AD;">{{ verificationCode }}</span>
                        </p>
                    </td>
                </tr>

                <tr>
                    <td bgcolor="#E6E6E6" align="center" style="padding:20px; font-size:14px; color:#1A202C;">
                        <p style="margin:0 0 10px 0;">
                            {{ 'footer.support_team'|trans({}, 'admin_reset') }}
                            <a href="mailto:{{ contactEmail }}" style="color:#0B1A58; font-weight:bold; text-decoration:none;">{{ contactEmail }}</a>
                        </p>
                        <p style="margin:0;">
                            {{ 'footer.thank_you'|trans({}, 'admin_reset') }}<br/>
                            <strong style="color:#0B1A58;">{{ supportTeam }}</strong>
                        </p>
                    </td>
                </tr>

            </table>
        </td>
    </tr>
</table>

</body>
</html>