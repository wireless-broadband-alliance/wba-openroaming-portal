<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>{{ emailTitle }} - Password Reset Request</title>
</head>
<body style="margin:0; padding:0; font-family: Arial, Helvetica, sans-serif; background-color:#F4F4F4;">

<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#F4F4F4; margin:0; padding:0;">
    <tr>
        <td align="center">

            <!-- Container -->
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:1100px; background-color:#FFFFFF; margin:0 auto;">
                <tr>
                    <td>

                        <!-- Header -->
                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#0B1A58; text-align:center;">
                            <tr>
                                <td style="padding:40px 20px;">
                                    <img src="cid:logo_cid" alt="Customer Logo" style="max-width:300px; height:auto; border:0;"/>
                                </td>
                            </tr>
                        </table>

                        <!-- Content -->
                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="text-align:center; padding:40px 20px;">
                            <tr>
                                <td>
                                    <h1 style="color:#0B1A58; font-size:28px; font-weight:bold; margin:0 0 30px 0; line-height:1.2; font-family: Arial, Helvetica, sans-serif;">
                                        {{ 'header'|trans({}, 'user_forgot_password_request') }}
                                    </h1>
                                </td>
                            </tr>

                            <tr>
                                <td style="padding-bottom:20px;">
                                    <p style="font-size:18px; line-height:1.5; color:#0B1A58; margin:0; font-family: Arial, Helvetica, sans-serif;">
                                        {{ 'info'|trans({}, 'user_forgot_password_request')|raw }}
                                    </p>
                                </td>
                            </tr>

                            <tr>
                                <td style="padding-bottom:20px;">
                                    <p style="font-size:18px; line-height:1.5; color:#0B1A58; margin:0; font-family: Arial, Helvetica, sans-serif;">
                                        {{ 'instructions'|trans({}, 'user_forgot_password_request')|raw }}
                                    </p>
                                </td>
                            </tr>

                            <!-- Button -->
                            <tr>
                                <td>
                                    <a href="{{ absolute_url('/forgot-password/link') ~ '?' ~ 'uuid=' ~ uuid|url_encode ~ '&twoFaCode=' ~ verificationCode }}"
                                       style="display:inline-block; width:90%; max-width:800px; padding:18px; background-color:#7BBA29; color:#0B1A58; font-size:18px; font-weight:bold; text-align:center; text-decoration:none; border-radius:10px; font-family: Arial, Helvetica, sans-serif;">
                                        {{ 'reset_password_button'|trans({}, 'user_forgot_password_request') }}
                                    </a>
                                </td>
                            </tr>

                            <!-- Notice -->
                            <tr>
                                <td style="padding-top:15px;">
                                    <span style="display:block; font-size:12px; line-height:1.4; color:#0B1A58; font-family: Arial, Helvetica, sans-serif;">
                                        {{ 'notice'|trans({}, 'user_forgot_password_request')|raw }}
                                    </span>
                                </td>
                            </tr>
                        </table>

                        <!-- Footer -->
                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#E6E6E6; text-align:center; padding:20px;">
                            <tr>
                                <td>
                                    <p style="margin:12px 0; font-size:14px; color:#1A202C; font-family: Arial, Helvetica, sans-serif;">
                                        {{ 'footer.support_team'|trans({}, 'user_forgot_password_request') }}
                                        <a href="mailto:{{ contactEmail }}" style="color:#0B1A58; font-weight:bold; text-decoration:none;">{{ contactEmail }}</a>
                                    </p>
                                    <p style="margin:12px 0; font-size:14px; color:#1A202C; font-family: Arial, Helvetica, sans-serif;">
                                        {{ 'footer.thank_you'|trans({}, 'user_forgot_password_request') }}<br/>
                                        <strong style="color:#0B1A58;">{{ 'footer.team'|trans({'%emailTitle%': emailTitle}, 'user_forgot_password_request') }}</strong>
                                    </p>
                                </td>
                            </tr>
                        </table>

                    </td>
                </tr>
            </table>
            <!-- End Container -->

        </td>
    </tr>
</table>

</body>
</html>
