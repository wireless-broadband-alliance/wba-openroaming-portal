<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>{{ emailTitle }} - Password Reset Request</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet"/>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Poppins', sans-serif;
            background-color: #F4F4F4;
            color: #0B1A58;
        }

        .container {
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 15px rgba(0, 0, 0, 0.05);
        }

        .header {
            background-color: #7BBA29;
            color: #fff;
            padding: 2rem;
            text-align: center;
        }

        .header h1 {
            margin: 0;
            font-size: 1.875rem;
            font-weight: 700;
        }

        .content {
            padding: 2rem;
            font-size: 1.125rem;
        }

        .content p {
            margin-bottom: 1.5rem;
            line-height: 1.6;
        }

        .content ol {
            padding-left: 1.25rem;
            margin: 1.5rem 0;
        }

        .content li {
            margin-bottom: 1rem;
        }

        .btn {
            display: inline-block;
            padding: 1rem 2rem;
            background-color: #7BBA29;
            color: #0B1A58;
            font-weight: 700;
            text-align: center;
            text-decoration: none;
            border-radius: 10px;
            margin-top: 1.25rem;
        }

        .footer {
            background-color: #E6E6E6;
            padding: 1.5rem;
            text-align: center;
            font-size: 0.875rem;
            color: #1A202C;
        }

        .footer a {
            color: #0B1A58;
            text-decoration: underline;
            font-weight: 600;
        }

        .footer strong {
            font-weight: 700;
            color: #0B1A58;
        }

        @media only screen and (max-width: 600px) {
            .header h1 {
                font-size: 1.5rem;
            }

            .content {
                font-size: 1rem;
                padding: 1.5rem;
            }

            .btn {
                font-size: 1rem;
                padding: 0.75rem 1.5rem;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <!-- Header -->
    <div class="header">
        <h1>{{ 'header'|trans({}, 'user_forgot_password_request') }}</h1>
    </div>

    <!-- Content -->
    <div class="content">
        <p>{{ 'instructions'|trans({}, 'user_forgot_password_request') }}</p>
        <ol>
            <li>
                {{ 'steps.temporary_password'|trans({'%currentPassword%': currentPassword}, 'user_forgot_password_request')|raw }}
            </li>
            <li>
                {{ 'steps.validate_account'|trans({
                    '%resetLink%': absolute_url('/login/link') ~ '?' ~ 'uuid=' ~ uuid|url_encode ~ '&verificationCode=' ~ verificationCode
                }, 'user_forgot_password_request')|raw }}
            </li>
            <li>
                {{ 'steps.new_password'|trans({}, 'user_forgot_password_request') }}
            </li>
            <li>
                {{ 'steps.download_profile'|trans({}, 'user_forgot_password_request') }}
            </li>
        </ol>
        <p>{{ 'notice'|trans({}, 'user_forgot_password_request') }}</p>
    </div>

    <!-- Footer -->
    <div class="footer">
        <p>
            {{ 'footer.support_team'|trans({}, 'user_forgot_password_request') }}
            <a href="mailto:{{ contactEmail }}">{{ contactEmail }}</a>
        </p>
        <p>
            {{ 'footer.thank_you'|trans({}, 'user_forgot_password_request') }}<br/>
            <strong>{{ 'footer.team'|trans({'%emailTitle%': emailTitle}, 'user_forgot_password_request') }}</strong>
        </p>
    </div>
</div>
</body>
</html>
