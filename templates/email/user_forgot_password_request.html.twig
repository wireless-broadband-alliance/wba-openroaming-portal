<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ emailTitle }} - Password Reset Request</title>
</head>
<body style="background-color: #080D4A; font-family: ui-sans-serif, system-ui, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'; color: #4A5568; margin: 0; padding: 0;">
<div style="width: 100%; max-width: 600px; margin: 0 auto; padding: 3rem 1rem;">
    <div style="max-width: 600px; margin: 0 auto; background-color: #fff; border-radius: 16px; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1); overflow: hidden;">
        <!-- Header -->
        <div style="background-color: #7BBA29; color: #fff; padding: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <h1 style="margin: 0; font-size: 1.5rem; font-weight: 700; color: #fff;">
                {{ 'header'|trans({}, 'user_forgot_password_request') }}
            </h1>
        </div>

        <!-- Instructions -->
        <div style="padding: 1.5rem;">
            <p style="font-size: 1.125rem; margin-bottom: 1rem;">
                {{ 'instructions'|trans({}, 'user_forgot_password_request') }}
            </p>
            <ol style="margin-top: 1rem; font-size: 1.125rem; list-style-type: decimal; list-style-position: inside; padding-left: 0; margin-bottom: 0;">
                <li style="margin-bottom: 0.75rem;">
                    {{ 'steps.temporary_password'|trans({'%currentPassword%': currentPassword}, 'user_forgot_password_request')|raw }}
                </li>
                <li style="margin-bottom: 0.75rem;">
                    {{ 'steps.validate_account'|trans({'%resetLink%': absolute_url('/login/link') ~ '?' ~ 'uuid=' ~ uuid|url_encode ~ '&verificationCode=' ~ verificationCode}, 'user_forgot_password_request')|raw }}
                </li>
                <li style="margin-bottom: 0.75rem;">
                    {{ 'steps.new_password'|trans({}, 'user_forgot_password_request') }}
                </li>
                <li>
                    {{ 'steps.download_profile'|trans({}, 'user_forgot_password_request') }}
                </li>
            </ol>
            <p style="margin-top: 1.5rem; font-size: 1.125rem;">
                {{ 'notice'|trans({}, 'user_forgot_password_request') }}
            </p>
        </div>

        <!-- Footer -->
        <div style="background-color: #f4f4f4; text-align: center; padding: 1.5rem;">
            <p style="font-size: 0.875rem; color: #718096;">
                {{ 'footer.support_team'|trans({}, 'user_forgot_password_request') }}
                <a href="mailto:{{ contactEmail }}"
                   style="color: #0045AD; text-decoration: underline;">
                    {{ contactEmail }}
                </a>
            </p>
            <p style="font-size: 0.875rem; color: #718096;">
                {{ 'footer.thank_you'|trans({}, 'user_forgot_password_request') }}<br>
                <strong>{{ 'footer.team'|trans({'%emailTitle%': emailTitle}, 'user_forgot_password_request') }}</strong>
            </p>
        </div>
    </div>
</div>
</body>
</html>
